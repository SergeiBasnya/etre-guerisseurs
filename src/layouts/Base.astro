---
import '../styles/global.css';
import { SITE, CONTACT, asset } from '../consts';

interface Props {
  title?: string;
  description?: string;
  /** Image de partage social (chemin public/ ou URL absolue). */
  image?: string;
}

const {
  title = `${SITE.name} — Cabinet de soin & d'accompagnement`,
  description = SITE.baseline,
  image = 'hero-accueil.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
/** Résout un chemin (public/ ou URL) en URL absolue pour les balises sociales. */
const toAbs = (p: string): string =>
  new URL(p.startsWith('http') ? p : asset(p), Astro.site ?? SITE.url).href;
const ogImage = toAbs(image);

// Schema.org — entreprise locale + praticien (émis sur tout le site).
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE.url}/#business`,
  name: SITE.name,
  description: SITE.baseline,
  url: SITE.url,
  telephone: CONTACT.phoneHref.replace('tel:', ''),
  email: CONTACT.email,
  image: toAbs('hero-accueil.jpg'),
  address: {
    '@type': 'PostalAddress',
    streetAddress: CONTACT.address.street,
    postalCode: CONTACT.address.zip,
    addressLocality: CONTACT.address.city,
    addressCountry: 'FR',
  },
  areaServed: CONTACT.areaServed,
  founder: {
    '@type': 'Person',
    name: SITE.intervenant,
    jobTitle: 'Enseignant toltèque, accompagnant et magnétiseur',
  },
  knowsAbout: [
    'Accords toltèques',
    'magnétisme',
    'soins énergétiques',
    'accompagnement au changement',
    'cercles de pardon',
  ],
  priceRange: '€€',
};
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={asset('favicon.svg')} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Données structurées : entreprise locale + praticien -->
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />


    <!-- Polices -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=Mulish:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      // État scroll du header + masquage de la topbar
      const hdr = document.getElementById('hdr');
      const topbar = document.getElementById('topbar');
      addEventListener('scroll', () => {
        const s = scrollY > 60;
        hdr?.classList.toggle('scrolled', s);
        topbar?.classList.toggle('hidden', s);
      });

      // Apparition au scroll
      const io = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }),
        { threshold: 0.15 }
      );
      document.querySelectorAll<HTMLElement>('.reveal').forEach((el, i) => {
        el.style.transitionDelay = (i % 3) * 90 + 'ms';
        io.observe(el);
      });
    </script>
  </body>
</html>
