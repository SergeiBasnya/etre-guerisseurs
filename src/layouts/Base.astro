---
import '../styles/global.css';
import { SITE, CONTACT, SOCIALS, asset } from '../consts';

interface Props {
  title?: string;
  description?: string;
  /** Image de partage social (chemin public/ ou URL absolue). */
  image?: string;
  /** Type Open Graph (website par défaut ; « article » pour le blog). */
  ogType?: string;
}

const {
  title = `${SITE.name} — Cabinet de soin & d'accompagnement`,
  description = SITE.baseline,
  image = 'hero-accueil.webp',
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
// Accueil : on précharge l'image hero (élément LCP) pour accélérer le rendu.
const isHome = Astro.url.pathname === '/';
/** Résout un chemin (public/ ou URL) en URL absolue pour les balises sociales. */
const toAbs = (p: string): string =>
  new URL(p.startsWith('http') ? p : asset(p), Astro.site ?? SITE.url).href;
const ogImage = toAbs(image);

// Schema.org — entreprise locale + praticien (émis sur tout le site).
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HealthAndBeautyBusiness',
  '@id': `${SITE.url}/#business`,
  name: SITE.name,
  description: SITE.baseline,
  url: SITE.url,
  telephone: CONTACT.phoneHref.replace('tel:', ''),
  email: CONTACT.email,
  image: toAbs('hero-accueil.webp'),
  address: {
    '@type': 'PostalAddress',
    streetAddress: CONTACT.address.street,
    postalCode: CONTACT.address.zip,
    addressLocality: CONTACT.address.city,
    addressCountry: 'FR',
  },
  // Coordonnées du cabinet de Mollans-sur-Ouvèze (signal local + Maps).
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 44.1862,
    longitude: 5.1721,
  },
  areaServed: CONTACT.areaServed,
  founder: {
    '@type': 'Person',
    name: SITE.intervenant,
    jobTitle: 'Enseignant toltèque, accompagnant et magnétiseur',
  },
  knowsAbout: [
    'Accords toltèques',
    'magnétisme',
    'soins énergétiques',
    'accompagnement au changement',
    'cercles de pardon',
  ],
  priceRange: '€€',
  ...(Object.values(SOCIALS).filter((u) => u !== '#').length
    ? { sameAs: Object.values(SOCIALS).filter((u) => u !== '#') }
    : {}),
};

// Schema.org WebSite — ancre l'entité du site (Knowledge Graph, citations IA).
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  name: SITE.name,
  url: SITE.url,
  description: SITE.baseline,
  inLanguage: 'fr-FR',
  publisher: { '@id': `${SITE.url}/#business` },
};
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={asset('favicon.svg')} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — Blog`}
      href={asset('rss.xml')}
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* Perf : précharger l'image LCP de l'accueil + les 2 polices principales
        (latin, poids courant) pour réduire le LCP et le FOUT. */}
    {isHome && (
      <link rel="preload" as="image" href={asset('hero-accueil.webp')} fetchpriority="high" />
    )}
    <link rel="preload" as="font" type="font/woff2" href={asset('fonts/f5.woff2')} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={asset('fonts/f10.woff2')} crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Données structurées : entreprise locale + site -->
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />


    <!-- Polices auto-hébergées (conformité RGPD : aucun appel à Google ; + perf) -->
    <link rel="stylesheet" href={asset('fonts/fonts.css')} />
  </head>
  <body>
    <slot />

    <script>
      // État scroll du header + masquage de la topbar
      const hdr = document.getElementById('hdr');
      const topbar = document.getElementById('topbar');
      addEventListener('scroll', () => {
        const s = scrollY > 60;
        hdr?.classList.toggle('scrolled', s);
        topbar?.classList.toggle('hidden', s);
      });

      // Apparition au scroll
      const io = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }),
        { threshold: 0.15 }
      );
      document.querySelectorAll<HTMLElement>('.reveal').forEach((el, i) => {
        el.style.transitionDelay = (i % 3) * 90 + 'ms';
        io.observe(el);
      });
    </script>
  </body>
</html>
