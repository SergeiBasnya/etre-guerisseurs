---
import Base from './Base.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import type { Crumb } from '../components/Breadcrumb.astro';
import Closing from '../components/Closing.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';

interface Props {
  /** Titre <title> SEO. Par défaut : "{h1} — {SITE.name}". */
  title?: string;
  /** Meta description SEO. */
  description?: string;
  /** Surtitre du bandeau. */
  eyebrow: string;
  /** Titre principal H1. */
  h1: string;
  /** Chapô sous le titre. */
  lede?: string;
  /** Fil d'Ariane (sans l'accueil). */
  crumbs: Crumb[];
  /** Masquer le bloc CTA de fin. */
  hideClosing?: boolean;
  /**
   * Image de fond du bandeau (variante illustrée).
   * Si fournie, le bandeau passe en sombre avec voile dégradé sur l'image,
   * sur le modèle du hero d'accueil. Sinon, bandeau crème sobre par défaut.
   */
  bandImage?: string;
}

const {
  h1,
  eyebrow,
  lede,
  crumbs,
  description,
  hideClosing = false,
  bandImage,
  title = `${h1} — ${SITE.name}`,
} = Astro.props;
const hasImage = Boolean(bandImage);
---

<Base title={title} description={description ?? lede}>
  <TopBar />
  <Header />

  <div class={`page-band ${hasImage ? 'has-image' : ''}`}>
    {
      hasImage && (
        <div class="page-band-bg" aria-hidden="true">
          <img src={bandImage} alt="" />
        </div>
      )
    }
    <div class="container">
      <Breadcrumb crumbs={crumbs} />
      <p class="eyebrow">{eyebrow}</p>
      <h1>{h1}</h1>
      {lede && <p class="lede">{lede}</p>}
    </div>
  </div>

  <main>
    <slot />
  </main>

  {!hideClosing && <Closing />}
  <Footer />
</Base>

<style>
  .page-band {
    /* dégage la topbar (42px) + header fixe */
    padding: 150px 0 56px;
    background: var(--bg-warm);
    border-bottom: 1px solid var(--line);
    position: relative;
  }
  .page-band .container {
    position: relative;
    z-index: 1;
  }
  .page-band .eyebrow {
    margin-top: 22px;
  }
  .page-band h1 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-bottom: 18px;
  }
  .page-band .lede {
    margin-top: 4px;
  }

  /* ===== Variante illustrée (image de fond + voile) ===== */
  .page-band.has-image {
    padding-top: 200px;
    padding-bottom: 80px;
    border-bottom: none;
    color: var(--bg);
  }
  .page-band-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .page-band-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .page-band-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(30, 25, 21, 0.82) 0%,
      rgba(30, 25, 21, 0.62) 45%,
      rgba(30, 25, 21, 0.35) 100%
    );
  }
  .page-band.has-image h1 {
    color: var(--bg);
  }
  .page-band.has-image .lede {
    color: rgba(250, 246, 240, 0.82);
  }
  /* fil d'Ariane + surtitre lisibles sur fond sombre */
  .page-band.has-image .eyebrow {
    color: var(--gold);
  }
  .page-band.has-image :global(.breadcrumb),
  .page-band.has-image :global(.breadcrumb a),
  .page-band.has-image :global(.breadcrumb [aria-current='page']) {
    color: rgba(250, 246, 240, 0.85);
  }

  main {
    padding: 0;
  }
  @media (max-width: 900px) {
    .page-band {
      padding: 120px 0 44px;
    }
    .page-band.has-image {
      padding-top: 150px;
      padding-bottom: 60px;
    }
  }
</style>
