---
import { ROUTES } from '../consts';

const HERO_IMG =
  'https://images.unsplash.com/photo-1518241353330-0f7941c2d9b5?q=80&w=2400&auto=format&fit=crop';

const avatars = [
  'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=200&auto=format&fit=crop',
  'https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=200&auto=format&fit=crop',
  'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=200&auto=format&fit=crop',
];
---

<section class="hero" style={`--hero-img:url('${HERO_IMG}')`}>
  <div class="container">
    <div class="hero-content">
      <p class="kicker">Cabinet de soin & d'accompagnement · Voie toltèque</p>
      <h1>Le chemin vers <span class="em">soi</span> commence ici.</h1>
      <p class="hero-sub">
        Magnétisme, soins énergétiques et enseignements toltèques pour devenir le
        créateur de sa vie et en faire une œuvre d'art.
      </p>
      <a href={ROUTES.stagesRetraites} class="btn btn-light">Découvrir les stages</a>
    </div>
  </div>
  <div class="reassure">
    <div class="avatars">
      {avatars.map((src) => <span style={`background-image:url('${src}')`} />)}
    </div>
    <div class="stat">
      <div class="n">+2 500</div>
      <div class="l">Personnes accompagnées</div>
    </div>
    <div class="divider"></div>
    <div class="rating">
      <div class="stars">★★★★★</div>
      <div class="src">4,9/5 · Avis Google</div>
    </div>
  </div>
  <span class="scroll-hint">défiler ↓</span>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 0;
    background: linear-gradient(
        105deg,
        rgba(30, 40, 42, 0.7) 0%,
        rgba(30, 40, 42, 0.45) 35%,
        rgba(30, 40, 42, 0.12) 60%,
        rgba(30, 40, 42, 0.3) 100%
      ),
      var(--hero-img) center top / cover;
    color: var(--white);
  }
  .hero .container {
    width: 100%;
    display: flex;
    justify-content: flex-start;
  }
  .hero-content {
    max-width: 620px;
    text-align: left;
    animation: rise 1.3s cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }
  .kicker {
    font-size: 0.82rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 22px;
    opacity: 0.92;
    font-weight: 500;
  }
  h1 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(2.8rem, 6.5vw, 5.6rem);
    line-height: 1;
    letter-spacing: -0.015em;
    margin-bottom: 28px;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.25);
  }
  h1 .em {
    font-weight: 400;
  }
  .hero-sub {
    font-size: 1.12rem;
    max-width: 440px;
    margin-bottom: 36px;
    opacity: 0.94;
    line-height: 1.55;
  }
  .reassure {
    position: absolute;
    bottom: 38px;
    right: 32px;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 22px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(6px);
    border-radius: 14px;
    padding: 14px 22px;
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.18);
    animation: rise 1.6s 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }
  .avatars {
    display: flex;
  }
  .avatars span {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 2px solid #fff;
    background-size: cover;
    background-position: center;
    margin-left: -10px;
  }
  .avatars span:first-child {
    margin-left: 0;
  }
  .stat .n {
    font-family: var(--serif);
    font-size: 1.15rem;
    color: var(--ink);
    line-height: 1;
  }
  .stat .l {
    font-size: 0.72rem;
    color: var(--ink-soft);
    margin-top: 2px;
  }
  .divider {
    width: 1px;
    height: 34px;
    background: var(--line);
  }
  .rating .stars {
    color: var(--gold);
    font-size: 0.95rem;
    letter-spacing: 1px;
  }
  .rating .src {
    font-size: 0.7rem;
    color: var(--ink-soft);
    margin-top: 3px;
  }
  .scroll-hint {
    position: absolute;
    bottom: 34px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.8;
    animation: bob 2s ease-in-out infinite;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(34px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes bob {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(8px);
    }
  }

  @media (max-width: 900px) {
    .hero .container {
      justify-content: flex-start;
    }
    .hero-content {
      max-width: 100%;
    }
    .reassure {
      right: 16px;
      left: 16px;
      bottom: 20px;
      justify-content: center;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-content,
    .reassure,
    .scroll-hint {
      animation: none;
    }
  }
</style>
