---
/** Bande d'orientation : les 3 piliers de l'activité (accueil). */
import { ROUTES } from '../consts';

const pillars = [
  {
    tag: 'Enseignement',
    title: 'Accords toltèques',
    text: "Cours, stages, formations et retraites pour apprendre et maîtriser la voie toltèque, au rythme des saisons.",
    href: ROUTES.enseignement,
  },
  {
    tag: 'Accompagnement',
    title: 'Individuel & personnalisé',
    text: "Coaching d'Être, entretiens d'écoute, protocole de pardon et marches pour cheminer vers le changement.",
    href: ROUTES.accompagnement,
  },
  {
    tag: 'Thérapies',
    title: 'Soins par les mains',
    text: 'Magnétisme et soins énergétiques pour soulager le corps et apaiser le système nerveux.',
    href: ROUTES.soins,
  },
];
---

<section class="pillars">
  <div class="container">
    <div class="pillars-grid">
      {
        pillars.map((p) => (
          <a class="pillar reveal" href={p.href}>
            <span class="pillar-tag">{p.tag}</span>
            <h3>{p.title}</h3>
            <p>{p.text}</p>
            <span class="pillar-link">Explorer →</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .pillars {
    padding: 90px 0;
    background: var(--bg);
  }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .pillar {
    display: block;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 36px 32px;
    transition: all 0.35s ease;
  }
  .pillar:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 40px rgba(46, 38, 32, 0.13);
    border-color: transparent;
  }
  .pillar-tag {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .pillar h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.5rem;
    margin-bottom: 12px;
  }
  .pillar p {
    color: var(--ink-soft);
    font-size: 0.97rem;
    margin-bottom: 18px;
  }
  .pillar-link {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 600;
  }
  @media (max-width: 900px) {
    .pillars-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
