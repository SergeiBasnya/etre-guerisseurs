---
import { DISCIPLINES } from '../data/disciplines';
---

<section class="disc" id="disciplines">
  <div class="container">
    <p class="eyebrow reveal">Vous êtes plutôt ?</p>
    <h2 class="section-title reveal">Trouvez votre <span class="em">voie</span></h2>
    <div class="disc-grid">
      {
        DISCIPLINES.map((d) => (
          <a class="disc-item reveal" href={d.href}>
            <img src={d.image} alt={d.imageAlt} loading="lazy" />
            <div class="disc-cap">
              <p class="tiny">{d.kind}</p>
              <h3>{d.title}</h3>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .disc {
    background: var(--bg-warm);
  }
  .disc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 50px;
  }
  .disc-item {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: flex-end;
    color: var(--white);
  }
  .disc-item img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s ease;
    z-index: 0;
  }
  .disc-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 35%, rgba(46, 38, 32, 0.78));
    z-index: 1;
  }
  .disc-item:hover img {
    transform: scale(1.08);
  }
  .disc-cap {
    position: relative;
    z-index: 2;
    padding: 26px;
  }
  .disc-cap .tiny {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.85;
    margin-bottom: 6px;
  }
  .disc-cap h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.5rem;
  }
  @media (max-width: 900px) {
    .disc-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
