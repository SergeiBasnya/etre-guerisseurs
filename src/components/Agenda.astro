---
import eventsData from '../data/events.json';

interface AgendaEvent {
  id: string;
  day: string;
  month: string;
  title: string;
  location: string;
  price: string;
  free: boolean;
  url: string;
}

const events = eventsData.events as AgendaEvent[];
const fromFacebook = eventsData.source === 'facebook';
---

<section id="agenda">
  <div class="container">
    <div class="agenda-head">
      <div>
        <p class="eyebrow reveal">Agenda</p>
        <h2 class="section-title reveal">
          Les prochaines <span class="em">rencontres</span>
        </h2>
      </div>
      {
        fromFacebook && (
          <p class="badge-fb reveal" style="margin-bottom:8px">
            Synchronisé depuis Facebook
          </p>
        )
      }
    </div>
    <div class="events">
      {
        events.map((ev) => (
          <div class="event reveal">
            <div class="event-date">
              <div class="day">{ev.day}</div>
              <div class="mo">{ev.month}</div>
            </div>
            <div class="event-main">
              <h3>{ev.title}</h3>
              <p class="event-loc">{ev.location}</p>
            </div>
            <div class="event-cta">
              <div class={ev.free ? 'event-price free' : 'event-price'}>
                {ev.price}
              </div>
              <a class="card-link" href={ev.url}>
                S'inscrire →
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .agenda-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
  }
  .events {
    margin-top: 50px;
    border-top: 1px solid var(--line);
  }
  .event {
    display: grid;
    grid-template-columns: 160px 1fr auto;
    gap: 34px;
    align-items: center;
    padding: 30px 0;
    border-bottom: 1px solid var(--line);
    transition: all 0.35s ease;
  }
  .event:hover {
    padding-left: 18px;
    background: linear-gradient(90deg, var(--bg-warm), transparent);
  }
  .event-date {
    text-align: center;
    border-right: 1px solid var(--line);
    padding-right: 30px;
  }
  .event-date .day {
    font-family: var(--serif);
    font-size: 2.6rem;
    line-height: 1;
    color: var(--terra);
  }
  .event-date .mo {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-top: 6px;
  }
  .event-main h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.4rem;
    margin-bottom: 8px;
    line-height: 1.2;
  }
  .event-loc {
    font-size: 0.86rem;
    color: var(--ink-soft);
  }
  .event-loc::before {
    content: '◈  ';
    color: var(--gold);
  }
  .event-cta {
    text-align: right;
  }
  .event-price {
    font-family: var(--serif);
    font-size: 1.2rem;
    color: var(--ink);
    margin-bottom: 10px;
  }
  .event-price.free {
    color: var(--sage);
  }
  .badge-fb {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
  }
  .badge-fb::before {
    content: '⟳';
    font-size: 0.9rem;
  }
  @media (max-width: 900px) {
    .event {
      grid-template-columns: 90px 1fr;
      gap: 20px;
    }
    .event-cta {
      grid-column: 2;
      text-align: left;
      margin-top: 8px;
    }
    .event-date {
      padding-right: 18px;
    }
    .event-date .day {
      font-size: 2rem;
    }
  }
</style>
