---
import eventsData from '../data/events.json';
import { ROUTES } from '../consts';

interface AgendaEvent {
  id: string;
  slug?: string;
  day: string;
  month: string;
  year?: string;
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  location?: string;
  price: string;
  free: boolean;
  url: string;
  ctaLabel?: string;
}

const events = eventsData.events as AgendaEvent[];
const fromFacebook =
  eventsData.source === 'facebook' || eventsData.source === 'merged';

/** Lien Google Maps à partir d'un lieu. On ne garde que la partie adresse
 *  (avant un éventuel « · » qui sépare la date), pour une recherche propre. */
function mapsUrl(loc?: string): string | null {
  if (!loc) return null;
  const place = loc.split('·')[0].trim();
  if (!place) return null;
  return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(place)}`;
}

/** Lien vers la page de détail de l'événement sur le site. */
function detailUrl(ev: AgendaEvent): string {
  return `${ROUTES.agenda}${ev.slug ?? ev.id}/`;
}
---

<section id="agenda">
  <div class="container">
    <div class="agenda-head">
      <div>
        <p class="eyebrow reveal">Agenda</p>
        <h2 class="section-title reveal">
          Les prochaines <span class="em">rencontres</span>
        </h2>
      </div>
      {
        fromFacebook && (
          <p class="badge-fb reveal" style="margin-bottom:8px">
            Synchronisé depuis Facebook
          </p>
        )
      }
    </div>

    <div class="events">
      {
        events.map((ev) => {
          const maps = mapsUrl(ev.location);
          const detail = detailUrl(ev);
          return (
            <article class="event reveal">
              <a class={ev.image ? 'ev-visual' : 'ev-visual is-empty'} href={detail} aria-label={ev.title}>
                {ev.image && (
                  <img src={ev.image} alt={ev.imageAlt ?? ev.title} loading="lazy" />
                )}
                <div class="ev-date">
                  <span class="d">{ev.day}</span>
                  <span class="m">{ev.month}</span>
                  {ev.year && <span class="y">{ev.year}</span>}
                </div>
              </a>

              <div class="ev-main">
                <h3>
                  <a class="ev-title-link" href={detail}>{ev.title}</a>
                </h3>
                {ev.description && <p class="ev-desc">{ev.description}</p>}
                <div class="ev-foot">
                  <span class={ev.free ? 'ev-price free' : 'ev-price'}>{ev.price}</span>
                  <a class="card-link" href={detail}>
                    Voir l'événement →
                  </a>
                </div>
              </div>

              {ev.location && (
                <aside class="ev-loc">
                  <span class="ev-loc-ic" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                      <path
                        d="M12 21s-6-5.3-6-10a6 6 0 1 1 12 0c0 4.7-6 10-6 10z"
                        stroke="currentColor"
                        stroke-width="1.4"
                      />
                      <circle cx="12" cy="11" r="2.2" stroke="currentColor" stroke-width="1.4" />
                    </svg>
                  </span>
                  <address>{ev.location}</address>
                  {maps && (
                    <a class="ev-map" href={maps} target="_blank" rel="noopener">
                      + Google Maps
                    </a>
                  )}
                </aside>
              )}
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .agenda-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
  }
  .events {
    margin-top: 50px;
    display: grid;
    gap: 28px;
  }

  .event {
    display: grid;
    grid-template-columns: 240px 1fr 230px;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    transition: box-shadow 0.35s ease, transform 0.35s ease;
  }
  .event:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(46, 38, 32, 0.12);
  }

  /* Colonne visuel + badge date */
  .ev-visual {
    display: block;
    position: relative;
    min-height: 200px;
    background: var(--bg-warm);
  }
  .ev-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ev-visual.is-empty {
    display: grid;
    place-items: center;
    background: linear-gradient(160deg, var(--terra), var(--terra-deep));
  }
  .ev-date {
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 22px 26px;
    background: rgba(193, 102, 56, 0.94); /* terra translucide */
    color: var(--white);
    min-width: 96px;
    height: 100%;
  }
  .ev-visual.is-empty .ev-date {
    position: static;
    background: transparent;
    height: auto;
  }
  .ev-date .d {
    font-family: var(--serif);
    font-size: 2.7rem;
    line-height: 1;
  }
  .ev-date .m {
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-top: 4px;
  }
  .ev-date .y {
    font-size: 0.78rem;
    opacity: 0.85;
    margin-top: 6px;
  }

  /* Colonne contenu */
  .ev-main {
    padding: 26px 30px;
    display: flex;
    flex-direction: column;
  }
  .ev-main h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.4rem;
    line-height: 1.25;
    margin-bottom: 12px;
  }
  .ev-title-link {
    color: var(--terra-deep);
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s ease;
  }
  .ev-title-link:hover {
    border-bottom-color: var(--terra);
  }
  .ev-desc {
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.55;
    margin-bottom: 18px;
  }
  .ev-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
  }
  .ev-price {
    font-family: var(--serif);
    font-size: 1.15rem;
    color: var(--ink);
  }
  .ev-price.free {
    color: var(--sage);
  }

  /* Colonne lieu */
  .ev-loc {
    padding: 26px 28px;
    background: var(--bg);
    border-left: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 0.9rem;
  }
  .ev-loc-ic {
    color: var(--gold);
    width: 24px;
    height: 24px;
  }
  .ev-loc-ic svg {
    width: 24px;
    height: 24px;
  }
  .ev-loc address {
    font-style: normal;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .ev-map {
    color: var(--terra);
    font-weight: 500;
    align-self: flex-start;
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s ease;
  }
  .ev-map:hover {
    border-bottom-color: var(--terra);
  }

  .badge-fb {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
  }
  .badge-fb::before {
    content: '⟳';
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .event {
      grid-template-columns: 150px 1fr;
    }
    .ev-loc {
      grid-column: 1 / -1;
      border-left: none;
      border-top: 1px solid var(--line);
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 6px 14px;
    }
    .ev-loc address {
      flex: 1 1 auto;
    }
  }
  @media (max-width: 560px) {
    .event {
      grid-template-columns: 1fr;
    }
    .ev-visual {
      min-height: 160px;
      aspect-ratio: 16 / 9;
    }
    .ev-visual.is-empty {
      aspect-ratio: auto;
      min-height: 0;
      padding: 20px 0;
    }
    .ev-date {
      min-width: 0;
      padding: 14px 20px;
    }
    .ev-date .d {
      font-size: 2.1rem;
    }
  }
</style>
