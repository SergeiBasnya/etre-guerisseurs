---
/**
 * Carte d'article de blog. Reprend exactement le traitement des cartes de
 * Stages.astro (image cover en aspect, zoom 1s au hover, tag, meta sage,
 * titre serif). Utilisable seule ou dans BlogGrid.
 */
export interface Article {
  title: string;
  href: string;
  image: string;
  imageAlt?: string;
  /** Rubrique affichée en pastille sur l'image. */
  category?: string;
  /** Date + temps de lecture, ex. « 12 mars · 5 min ». */
  meta?: string;
  excerpt?: string;
}
interface Props {
  article: Article;
}
const { article } = Astro.props;
---

<article class="ac reveal">
  <a href={article.href} class="ac-link" aria-label={article.title}>
    <div class="ac-img">
      {article.category && <span class="ac-tag">{article.category}</span>}
      <img src={article.image} alt={article.imageAlt ?? ''} loading="lazy" />
    </div>
    <div class="ac-body">
      {article.meta && <p class="ac-meta">{article.meta}</p>}
      <h3>{article.title}</h3>
      {article.excerpt && <p class="ac-excerpt">{article.excerpt}</p>}
      <span class="card-link">Lire l’article →</span>
    </div>
  </a>
</article>

<style>
  .ac {
    background: var(--white);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(46, 38, 32, 0.06);
    transition: all 0.4s ease;
  }
  .ac:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 40px rgba(46, 38, 32, 0.13);
  }
  .ac-link {
    display: block;
  }
  .ac-img {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    position: relative;
  }
  .ac-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s ease;
  }
  .ac:hover .ac-img img {
    transform: scale(1.06);
  }
  .ac-tag {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(250, 246, 240, 0.92);
    color: var(--terra-deep);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 13px;
    border-radius: 20px;
    font-weight: 600;
  }
  .ac-body {
    padding: 24px 26px 30px;
  }
  .ac-meta {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .ac-body h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.32rem;
    line-height: 1.25;
    margin-bottom: 12px;
  }
  .ac-excerpt {
    color: var(--ink-soft);
    font-size: 0.96rem;
    margin-bottom: 16px;
  }
</style>
