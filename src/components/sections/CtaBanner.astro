---
/**
 * Encart de conversion contextuel.
 * Deux variantes de fond : « ink » (sombre premium, façon Values.astro,
 * avec halo gold) et « warm » (sobre, façon Closing.astro). À glisser au fil
 * d'une page longue ou en fin de section prestation.
 */
interface Props {
  title?: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
  /** Bouton secondaire optionnel. */
  altLabel?: string;
  altHref?: string;
  variant?: 'ink' | 'warm';
  /** Surtitre optionnel au-dessus du titre. */
  eyebrow?: string;
}

const {
  title = 'Et si on en <span class="em">parlait</span> ?',
  text = 'Un échange sans engagement pour cerner votre besoin et trouver le bon point de départ.',
  ctaLabel = 'Prendre contact',
  ctaHref = '/contact/',
  altLabel,
  altHref,
  variant = 'ink',
  eyebrow,
} = Astro.props;
---

<section class={`cta cta-${variant}`}>
  <div class="container">
    {eyebrow && <p class="eyebrow reveal">{eyebrow}</p>}
    <h2 class="reveal" set:html={title} />
    {text && <p class="cta-text reveal">{text}</p>}
    <div class="cta-actions reveal">
      <a href={ctaHref} class={variant === 'ink' ? 'btn btn-light' : 'btn'}>
        {ctaLabel}
      </a>
      {
        altLabel && altHref && (
          <a href={altHref} class="btn btn-ghost cta-alt">
            {altLabel}
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .cta {
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-warm {
    background: var(--bg-warm);
  }
  .cta-ink {
    background: var(--ink);
    color: var(--bg);
  }
  /* halo gold repris de Values.astro */
  .cta-ink::before {
    content: '';
    position: absolute;
    top: -140px;
    left: 50%;
    transform: translateX(-50%);
    width: 520px;
    height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(199, 154, 78, 0.16), transparent 70%);
    pointer-events: none;
  }
  .cta h2 {
    position: relative;
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.1;
    max-width: 760px;
    margin: 0 auto 22px;
  }
  .cta-text {
    position: relative;
    max-width: 560px;
    margin: 0 auto 30px;
    font-size: 1.06rem;
  }
  .cta-ink .cta-text {
    color: rgba(250, 246, 240, 0.72);
  }
  .cta-warm .cta-text {
    color: var(--ink-soft);
  }
  .cta-actions {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }
  .cta-ink .eyebrow {
    color: var(--gold);
    position: relative;
  }
  /* bouton fantôme lisible sur fond sombre */
  .cta-ink .cta-alt {
    border-color: rgba(250, 246, 240, 0.5);
    color: var(--bg);
  }
  .cta-ink .cta-alt:hover {
    background: rgba(250, 246, 240, 0.12);
    color: var(--bg);
  }
</style>
