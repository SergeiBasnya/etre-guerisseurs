---
/**
 * Liste à pastilles « pour qui / bienfaits ».
 * Grille de 2 ou 3 colonnes, chaque item = pastille ronde (icône SVG inline
 * ou puce sobre) + titre serif + texte court. Pas de carte : on s'appuie sur
 * l'air et un filet supérieur discret façon Values.astro.
 */
export interface IconItem {
  /** Nom de glyphe interne, ou rien pour une puce générique. */
  icon?: 'leaf' | 'heart' | 'hand' | 'spark' | 'moon' | 'circle';
  title: string;
  text?: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  lede?: string;
  items?: IconItem[];
  columns?: 2 | 3;
  bg?: 'cream' | 'warm' | 'white';
}

const {
  eyebrow = 'Pour qui ?',
  title = 'À qui s’adresse <span class="em">cet accompagnement</span>',
  lede,
  columns = 3,
  bg = 'cream',
  items = [
    {
      icon: 'heart',
      title: 'Traverser une épreuve',
      text: 'Deuil, séparation, période de doute : retrouver un appui et une stabilité intérieure.',
    },
    {
      icon: 'spark',
      title: 'Apaiser le mental',
      text: 'Stress chronique, charge émotionnelle, fatigue nerveuse — relâcher la pression accumulée.',
    },
    {
      icon: 'leaf',
      title: 'Se reconnecter',
      text: 'Renouer avec son corps, ses ressentis et un rythme de vie plus juste.',
    },
    {
      icon: 'hand',
      title: 'Soutenir un soin',
      text: 'En complément d’un suivi médical, jamais en substitution, pour accompagner le terrain.',
    },
    {
      icon: 'moon',
      title: 'Préparer une étape',
      text: 'Aborder un changement important avec plus de clarté et de présence à soi.',
    },
    {
      icon: 'circle',
      title: 'Cheminer en conscience',
      text: 'Engager un travail de fond sur soi, à son rythme, séance après séance.',
    },
  ],
} = Astro.props;

const paths: Record<string, string> = {
  leaf: 'M5 21c0-7 4-13 14-16-1 9-6 15-14 16zm0 0c2-4 5-6 9-7',
  heart: 'M12 20s-7-4.6-9.3-9C1 7.6 2.7 4.5 6 4.5c2 0 3.2 1.2 4 2.4.8-1.2 2-2.4 4-2.4 3.3 0 5 3.1 3.3 6.5C19 15.4 12 20 12 20z',
  hand: 'M8 13V5.5a1.5 1.5 0 0 1 3 0V11m0-1V4.5a1.5 1.5 0 0 1 3 0V11m0-.5V6a1.5 1.5 0 0 1 3 0v7.5a6 6 0 0 1-6 6h-1a5 5 0 0 1-3.6-1.5L3 16',
  spark: 'M12 3v4m0 10v4m9-9h-4M7 12H3m13.5-6.5-2.8 2.8M9.3 14.7l-2.8 2.8m11 0-2.8-2.8M9.3 9.3 6.5 6.5',
  moon: 'M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z',
  circle: 'M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18zm0 5a4 4 0 1 0 0 8 4 4 0 0 0 0-8z',
};
---

<section class={`il bg-${bg}`}>
  <div class="container">
    {eyebrow && <p class="eyebrow reveal">{eyebrow}</p>}
    {title && <h2 class="section-title reveal" set:html={title} />}
    {lede && <p class="lede reveal">{lede}</p>}
    <ul class={`il-grid cols-${columns}`}>
      {
        items.map((it) => (
          <li class="il-item reveal">
            <span class="il-ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path
                  d={paths[it.icon ?? 'circle']}
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
            <div>
              <h3>{it.title}</h3>
              {it.text && <p>{it.text}</p>}
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .bg-cream {
    background: var(--bg);
  }
  .bg-warm {
    background: var(--bg-warm);
  }
  .bg-white {
    background: var(--white);
  }
  .il-grid {
    list-style: none;
    display: grid;
    gap: 40px 44px;
    margin-top: 54px;
  }
  .cols-2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .cols-3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .il-item {
    display: flex;
    gap: 18px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }
  .il-ic {
    flex: 0 0 auto;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--bg-warm);
    color: var(--terra);
    border: 1px solid var(--line);
  }
  /* sur fond warm, la pastille passe en blanc pour rester lisible */
  .bg-warm .il-ic {
    background: var(--white);
  }
  .il-ic svg {
    width: 21px;
    height: 21px;
  }
  .il-item h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.22rem;
    line-height: 1.25;
    margin-bottom: 8px;
  }
  .il-item p {
    color: var(--ink-soft);
    font-size: 0.96rem;
  }
  @media (max-width: 900px) {
    .cols-2,
    .cols-3 {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
