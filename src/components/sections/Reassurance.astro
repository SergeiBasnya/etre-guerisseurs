---
/**
 * Bande de réassurance horizontale (3 ou 4 points clés séparés par un filet).
 * Ton sobre, sans carte : sert de respiration entre une grille de hub et le
 * CTA, ou en tête de page locale. Reprend l'esprit du bloc .reassure du hero.
 */
export interface ReassureItem {
  /** Chiffre / mot fort affiché en serif. */
  figure: string;
  label: string;
}
interface Props {
  items?: ReassureItem[];
  bg?: 'cream' | 'warm' | 'white';
}
const {
  bg = 'white',
  items = [
    { figure: '15 ans', label: 'de pratique et de transmission' },
    { figure: '3 lieux', label: 'Nyons · Avignon · Nîmes' },
    { figure: 'Don Miguel Ruiz', label: 'formation à la source toltèque' },
    { figure: 'À distance', label: 'soins et formations partout en France' },
  ],
} = Astro.props;
---

<section class={`rs bg-${bg}`}>
  <div class="container">
    <ul class="rs-row reveal">
      {
        items.map((it) => (
          <li class="rs-item">
            <span class="rs-fig">{it.figure}</span>
            <span class="rs-label">{it.label}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .rs {
    padding: 64px 0;
  }
  .bg-cream {
    background: var(--bg);
  }
  .bg-warm {
    background: var(--bg-warm);
  }
  .bg-white {
    background: var(--white);
  }
  .rs-row {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 28px 0;
  }
  .rs-item {
    flex: 1 1 200px;
    text-align: center;
    padding: 0 28px;
    position: relative;
  }
  .rs-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 44px;
    background: var(--line);
  }
  .rs-fig {
    display: block;
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--terra-deep);
    margin-bottom: 6px;
  }
  .rs-label {
    font-size: 0.9rem;
    color: var(--ink-soft);
  }
  @media (max-width: 720px) {
    .rs-item {
      flex-basis: 50%;
    }
    .rs-item:nth-child(2n)::after {
      display: none;
    }
  }
</style>
