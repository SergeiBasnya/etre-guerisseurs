---
/**
 * Infos pratiques d'un lieu (adresse, accès, horaires) + carte placeholder.
 * Deux colonnes : liste d'infos à gauche, « carte » à droite (cadre sage
 * doux avec épingle, en attendant l'intégration d'une vraie carte).
 */
export interface InfoRow {
  /** Glyphe : pin, clock, car, phone, mail. */
  icon?: 'pin' | 'clock' | 'car' | 'phone' | 'mail';
  label: string;
  /** Valeur en HTML inline (liens tel:/mailto: autorisés). */
  value: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  lede?: string;
  rows?: InfoRow[];
  /** Légende affichée sur la carte placeholder. */
  mapLabel?: string;
  /** URL d'itinéraire (Google Maps…) pour le bouton. */
  directionsHref?: string;
  bg?: 'cream' | 'warm' | 'white';
}

const {
  eyebrow = 'Infos pratiques',
  title = 'Venir au <span class="em">cabinet</span>',
  lede,
  bg = 'warm',
  mapLabel = 'Nyons, Drôme provençale',
  directionsHref = '#',
  rows = [
    { icon: 'pin', label: 'Adresse', value: '7 Avenue de Verdun<br>26110 Nyons' },
    { icon: 'clock', label: 'Horaires', value: 'Lun – Ven · 9h – 19h<br>Sur rendez-vous' },
    { icon: 'car', label: 'Accès', value: 'Parking à 2 min à pied<br>Arrêt de bus « Centre » à 150 m' },
    { icon: 'phone', label: 'Téléphone', value: '<a href="tel:+33660808474">06 60 808 474</a>' },
  ],
} = Astro.props;

const paths: Record<string, string> = {
  pin: 'M12 21s7-6.3 7-11a7 7 0 1 0-14 0c0 4.7 7 11 7 11zm0-8.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z',
  clock: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18zm0-14v5l3.5 2',
  car: 'M5 16v2m14-2v2M4 16h16m-1 0-1.4-5.3A2 2 0 0 0 15.7 9H8.3a2 2 0 0 0-1.9 1.4L5 16m1.5-3h11M7 16a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm12 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0z',
  phone: 'M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24c1.1.37 2.3.57 3.5.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.2.2 2.4.57 3.5a1 1 0 0 1-.24 1l-2.2 2.3z',
  mail: 'M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1zm0 2 8 5 8-5',
};
---

<section class={`li bg-${bg}`}>
  <div class="container li-grid">
    <div class="li-text reveal">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      {title && <h2 class="section-title" set:html={title} />}
      {lede && <p class="lede" style="margin-bottom:14px">{lede}</p>}
      <ul class="li-rows">
        {
          rows.map((r) => (
            <li>
              <span class="li-ic" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path
                    d={paths[r.icon ?? 'pin']}
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <div>
                <p class="li-label">{r.label}</p>
                <p class="li-value" set:html={r.value} />
              </div>
            </li>
          ))
        }
      </ul>
      <a href={directionsHref} class="btn" style="margin-top:30px">Itinéraire</a>
    </div>

    <div class="li-map reveal" role="img" aria-label={`Emplacement : ${mapLabel}`}>
      <span class="li-pin" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path
            d={paths.pin}
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <span class="li-map-cap">{mapLabel}</span>
    </div>
  </div>
</section>

<style>
  .bg-cream {
    background: var(--bg);
  }
  .bg-warm {
    background: var(--bg-warm);
  }
  .bg-white {
    background: var(--white);
  }
  .li-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 64px;
    align-items: center;
  }
  .li-rows {
    list-style: none;
    margin-top: 36px;
    display: grid;
    gap: 24px;
  }
  .li-rows li {
    display: flex;
    gap: 16px;
  }
  .li-ic {
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--white);
    color: var(--terra);
    border: 1px solid var(--line);
  }
  .li-ic svg {
    width: 20px;
    height: 20px;
  }
  .li-label {
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .li-value {
    color: var(--ink-soft);
    font-size: 0.98rem;
    line-height: 1.5;
  }
  .li-value :global(a) {
    color: var(--terra);
    border-bottom: 1px solid var(--line);
  }
  .li-value :global(a:hover) {
    border-color: var(--terra);
  }

  /* carte placeholder */
  .li-map {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--line);
    background:
      radial-gradient(circle at 70% 30%, rgba(125, 132, 102, 0.16), transparent 60%),
      repeating-linear-gradient(
        0deg,
        var(--bg-warm),
        var(--bg-warm) 38px,
        var(--bg) 38px,
        var(--bg) 39px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 38px,
        rgba(227, 216, 200, 0.6) 38px,
        rgba(227, 216, 200, 0.6) 39px
      );
    display: grid;
    place-items: center;
  }
  .li-pin {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--white);
    color: var(--terra);
    box-shadow: 0 10px 24px rgba(46, 38, 32, 0.16);
  }
  .li-pin svg {
    width: 28px;
    height: 28px;
  }
  .li-map-cap {
    position: absolute;
    left: 18px;
    bottom: 16px;
    background: rgba(250, 246, 240, 0.92);
    color: var(--ink);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 6px 13px;
    border-radius: 20px;
  }
  @media (max-width: 900px) {
    .li-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
