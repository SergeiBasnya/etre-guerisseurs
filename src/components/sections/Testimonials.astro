---
/**
 * Cartes d'avis + note. Citation serif en exergue, auteur discret,
 * étoiles en gold. Grille fluide façon LinkGrid (cartes blanches).
 */
export interface Testimonial {
  quote: string;
  author: string;
  /** Lieu / contexte : « Stage Nyons », « Soin à Avignon ». */
  context?: string;
  /** Note sur 5 (entier). Omise = pas d'étoiles. */
  rating?: number;
}
interface Props {
  eyebrow?: string;
  title?: string;
  lede?: string;
  items?: Testimonial[];
  bg?: 'cream' | 'warm' | 'white';
}

const {
  eyebrow = 'Ils ont cheminé',
  title = 'Ce qu’ils en <span class="em">disent</span>',
  lede,
  bg = 'warm',
  items = [
    {
      quote:
        'Je suis arrivée épuisée et fermée. Je suis repartie avec une légèreté que je n’avais pas ressentie depuis des mois. Un accompagnement d’une rare justesse.',
      author: 'Claire M.',
      context: 'Soin à Nyons',
      rating: 5,
    },
    {
      quote:
        'Pierre-Alexandre a cette capacité à mettre des mots simples sur des choses complexes. Le stage a été un vrai tournant dans ma façon de me parler à moi-même.',
      author: 'Thomas R.',
      context: 'Stage les accords toltèques',
      rating: 5,
    },
    {
      quote:
        'Une présence apaisante et profondément respectueuse. Rien n’est imposé, tout est proposé. J’ai retrouvé confiance en mon propre rythme.',
      author: 'Nadia B.',
      context: 'Accompagnement à distance',
      rating: 5,
    },
  ],
} = Astro.props;
---

<section class={`tm bg-${bg}`}>
  <div class="container">
    {eyebrow && <p class="eyebrow reveal">{eyebrow}</p>}
    {title && <h2 class="section-title reveal" set:html={title} />}
    {lede && <p class="lede reveal">{lede}</p>}
    <div class="tm-grid">
      {
        items.map((t) => (
          <figure class="tm-card reveal">
            {typeof t.rating === 'number' && (
              <div
                class="tm-stars"
                aria-label={`Note ${t.rating} sur 5`}
                role="img"
              >
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={i < t.rating! ? 'on' : 'off'} aria-hidden="true">
                    ★
                  </span>
                ))}
              </div>
            )}
            <blockquote>{t.quote}</blockquote>
            <figcaption>
              <span class="tm-author">{t.author}</span>
              {t.context && <span class="tm-ctx">{t.context}</span>}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .bg-cream {
    background: var(--bg);
  }
  .bg-warm {
    background: var(--bg-warm);
  }
  .bg-white {
    background: var(--white);
  }
  .tm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 28px;
    margin-top: 54px;
  }
  .tm-card {
    display: flex;
    flex-direction: column;
    gap: 18px;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 34px 32px;
    transition: all 0.35s ease;
  }
  .tm-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(46, 38, 32, 0.12);
  }
  .tm-stars {
    letter-spacing: 2px;
    font-size: 0.95rem;
  }
  .tm-stars .on {
    color: var(--gold);
  }
  .tm-stars .off {
    color: var(--line);
  }
  .tm-card blockquote {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.16rem;
    line-height: 1.5;
    color: var(--ink);
  }
  .tm-card blockquote::before {
    content: '“';
    color: var(--terra);
    font-size: 1.4em;
    line-height: 0;
    vertical-align: -0.2em;
    margin-right: 2px;
  }
  .tm-card figcaption {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tm-author {
    font-weight: 600;
    font-size: 0.95rem;
  }
  .tm-ctx {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
  }
</style>
