---
/**
 * Bloc texte + image alterné (texte/image ou image/texte).
 * Reprend le langage de Intro.astro : grille 2 colonnes, image en
 * aspect 4/5 avec zoom doux au hover, liseré interne, chapô serif.
 *
 * Usage : intro illustrée d'une page de prestation, section éditoriale.
 */
interface Props {
  eyebrow?: string;
  title: string;
  /** Paragraphes du corps (HTML inline autorisé via set:html). */
  paragraphs?: string[];
  image?: string;
  imageAlt?: string;
  /** Image à gauche (par défaut à droite). */
  reverse?: boolean;
  /** Lien optionnel sous le texte. */
  ctaLabel?: string;
  ctaHref?: string;
  /** Variante de fond de la section. */
  bg?: 'cream' | 'warm' | 'white';
}

const {
  eyebrow,
  title,
  paragraphs = [
    "Recevoir un soin, c'est s'autoriser à déposer ce que l'on porte. Dans un cadre calme et bienveillant, le travail énergétique vient relâcher les tensions et rétablir une circulation plus fluide.",
    'Chaque séance s’adapte à la personne, à son histoire et à ce qu’elle traverse au moment présent — sans jamais forcer, toujours en respectant son rythme.',
  ],
  image = 'https://images.unsplash.com/photo-1545389336-cf090694435e?q=80&w=1400&auto=format&fit=crop',
  imageAlt = '',
  reverse = false,
  ctaLabel,
  ctaHref,
  bg = 'cream',
} = Astro.props;
---

<section class={`sf bg-${bg}`}>
  <div class={`container sf-grid ${reverse ? 'is-reverse' : ''}`}>
    <div class="sf-text reveal">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 class="section-title" set:html={title} />
      {paragraphs.map((p) => <p set:html={p} />)}
      {
        ctaLabel && ctaHref && (
          <a href={ctaHref} class="card-link" style="margin-top:24px">
            {ctaLabel}
          </a>
        )
      }
    </div>
    <div class="sf-img reveal">
      <img src={image} alt={imageAlt} loading="lazy" />
    </div>
  </div>
</section>

<style>
  .bg-cream {
    background: var(--bg);
  }
  .bg-warm {
    background: var(--bg-warm);
  }
  .bg-white {
    background: var(--white);
  }
  .sf-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  /* image avant texte */
  .sf-grid.is-reverse .sf-text {
    order: 2;
  }
  .sf-grid.is-reverse .sf-img {
    order: 1;
  }
  .sf-text p {
    margin-bottom: 18px;
    color: var(--ink-soft);
  }
  .sf-text .section-title {
    margin-bottom: 22px;
  }
  .sf-img {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }
  .sf-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s ease;
  }
  .sf-img:hover img {
    transform: scale(1.05);
  }
  .sf-img::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.4);
    border-radius: 6px;
  }
  @media (max-width: 900px) {
    .sf-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    /* sur mobile, l'image repasse toujours après le texte pour la lecture */
    .sf-grid.is-reverse .sf-text {
      order: 1;
    }
    .sf-grid.is-reverse .sf-img {
      order: 2;
    }
  }
</style>
