---
import { SITE, NAV, ROUTES } from '../consts';

const pathname = Astro.url.pathname;
// Une entrée est active si on est sur sa page ou une de ses pages enfants.
function isActive(href: string): boolean {
  if (href === ROUTES.home) return pathname === ROUTES.home;
  return pathname === href || pathname.startsWith(href);
}
---

<header id="hdr">
  <div class="container nav-inner">
    <a href={ROUTES.home} class="logo">
      {SITE.nameParts.lead} <span class="mark">{SITE.nameParts.mark}</span>
    </a>

    <nav aria-label="Navigation principale">
      <ul class="menu">
        {
          NAV.map((item) => (
            <li class={item.children ? 'has-sub' : ''}>
              <a
                href={item.href}
                class={[item.cta ? 'nav-cta' : '', isActive(item.href) ? 'active' : '']
                  .filter(Boolean)
                  .join(' ')}
                aria-current={isActive(item.href) ? 'page' : undefined}
                aria-haspopup={item.children ? 'true' : undefined}
              >
                {item.label}
                {item.children && <span class="caret" aria-hidden="true">▾</span>}
              </a>
              {item.children && (
                <ul class="submenu">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        aria-current={isActive(child.href) ? 'page' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      class="burger"
      id="burger"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Menu mobile (overlay) -->
  <div class="mobile-menu" id="mobile-menu" hidden>
    <ul>
      {
        NAV.map((item) => (
          <li>
            <a href={item.href} class={item.cta ? 'm-cta' : ''}>
              {item.label}
            </a>
            {item.children && (
              <ul class="m-sub">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href}>{child.label}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const burger = document.getElementById('burger');
  const panel = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    burger.setAttribute('aria-label', open ? 'Ouvrir le menu' : 'Fermer le menu');
    burger.classList.toggle('is-open', !open);
    if (panel) panel.hidden = open;
    document.body.style.overflow = open ? '' : 'hidden';
  });

  // Sous-menus desktop : ouverture au survol et au clavier (classe .open).
  document.querySelectorAll('.has-sub').forEach((li) => {
    li.addEventListener('mouseenter', () => li.classList.add('open'));
    li.addEventListener('mouseleave', () => li.classList.remove('open'));
    li.addEventListener('focusin', () => li.classList.add('open'));
    li.addEventListener('focusout', (e) => {
      if (!li.contains(e.relatedTarget)) li.classList.remove('open');
    });
  });
</script>

<style>
  header {
    position: fixed;
    top: 42px;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 14px 0;
    transition: all 0.4s ease;
    background: transparent;
  }
  header.scrolled {
    top: 0;
    background: rgba(250, 246, 240, 0.94);
    backdrop-filter: blur(12px);
    padding: 13px 0;
    box-shadow: 0 1px 0 var(--line);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: var(--serif);
    font-size: 1.5rem;
    letter-spacing: 0.02em;
    color: var(--white);
    transition: color 0.4s;
    z-index: 2;
  }
  .logo .mark {
    font-style: italic;
    color: var(--gold);
  }
  header.scrolled .logo {
    color: var(--ink);
  }

  /* ===== MENU DESKTOP ===== */
  .menu {
    display: flex;
    gap: 30px;
    list-style: none;
    align-items: center;
  }
  .menu > li {
    position: relative;
  }
  .menu a {
    font-size: 0.8rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--white);
    font-weight: 500;
    transition: color 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  header.scrolled .menu a {
    color: var(--ink-soft);
  }
  .menu a:hover,
  .menu a.active {
    color: var(--gold);
  }
  .caret {
    font-size: 0.7em;
    opacity: 0.8;
  }
  .nav-cta {
    border: 1px solid rgba(255, 255, 255, 0.5);
    padding: 9px 18px;
    border-radius: 30px;
    transition: all 0.3s;
  }
  header.scrolled .nav-cta {
    border-color: var(--terra);
    color: var(--terra) !important;
  }
  .nav-cta:hover {
    background: var(--terra);
    border-color: var(--terra);
    color: var(--white) !important;
  }

  /* sous-menu */
  .submenu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    min-width: 230px;
    background: var(--white);
    border-radius: 8px;
    box-shadow: 0 18px 44px rgba(46, 38, 32, 0.16);
    padding: 10px;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transition: all 0.28s ease;
    margin-top: 8px;
  }
  .submenu::before {
    /* zone tampon pour ne pas perdre le survol */
    content: '';
    position: absolute;
    top: -16px;
    left: 0;
    right: 0;
    height: 16px;
  }
  .has-sub.open > .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .submenu a {
    display: block;
    padding: 11px 16px;
    border-radius: 5px;
    color: var(--ink-soft) !important;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.92rem;
    font-weight: 400;
  }
  .submenu a:hover {
    background: var(--bg-warm);
    color: var(--terra) !important;
  }

  /* ===== BURGER ===== */
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 6px;
    z-index: 2;
  }
  .burger span {
    width: 26px;
    height: 2px;
    background: var(--white);
    transition: all 0.3s;
  }
  header.scrolled .burger span {
    background: var(--ink);
  }
  .burger.is-open span {
    background: var(--ink);
  }
  .burger.is-open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger.is-open span:nth-child(2) {
    opacity: 0;
  }
  .burger.is-open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ===== MENU MOBILE ===== */
  .mobile-menu {
    position: fixed;
    inset: 0;
    top: 0;
    background: var(--bg);
    padding: 110px 32px 40px;
    overflow-y: auto;
    z-index: 1;
  }
  .mobile-menu ul {
    list-style: none;
  }
  .mobile-menu > ul > li {
    border-bottom: 1px solid var(--line);
  }
  .mobile-menu > ul > li > a {
    display: block;
    padding: 18px 0;
    font-family: var(--serif);
    font-size: 1.5rem;
    color: var(--ink);
  }
  .mobile-menu .m-cta {
    color: var(--terra);
  }
  .m-sub {
    padding: 0 0 16px 14px;
  }
  .m-sub a {
    display: block;
    padding: 7px 0;
    color: var(--ink-soft);
    font-size: 1rem;
  }

  @media (max-width: 980px) {
    nav {
      display: none;
    }
    .burger {
      display: flex;
    }
  }
  @media (min-width: 981px) {
    .mobile-menu {
      display: none;
    }
  }
</style>
