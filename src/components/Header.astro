---
import { SITE, NAV, ROUTES } from '../consts';

interface Props {
  /** Header « solide » dès le haut (texte foncé sur fond crème) : à activer
   *  sur les pages à bandeau clair, où le menu blanc serait illisible. */
  solid?: boolean;
}
const { solid = false } = Astro.props;

const pathname = Astro.url.pathname;
// Une entrée est active si on est sur sa page ou une de ses pages enfants.
function isActive(href: string): boolean {
  if (href === ROUTES.home) return pathname === ROUTES.home;
  return pathname === href || pathname.startsWith(href);
}
---

<header id="hdr" class={solid ? 'solid' : ''}>
  <div class="container nav-inner">
    <a href={ROUTES.home} class="logo">
      {SITE.nameParts.lead} <span class="mark">{SITE.nameParts.mark}</span>
    </a>

    <nav aria-label="Navigation principale">
      <ul class="menu">
        {
          NAV.map((item) => (
            <li class={item.children ? 'has-sub' : ''}>
              <a
                href={item.href}
                class={[item.cta ? 'nav-cta' : '', isActive(item.href) ? 'active' : '']
                  .filter(Boolean)
                  .join(' ')}
                aria-current={isActive(item.href) ? 'page' : undefined}
                aria-haspopup={item.children ? 'true' : undefined}
              >
                {item.label}
                {item.children && <span class="caret" aria-hidden="true">▾</span>}
              </a>
              {item.children && (
                <div class="submenu" data-count={item.children.length}>
                  <div class="submenu-head">
                    <a class="submenu-title" href={item.href}>
                      {item.label}
                    </a>
                  </div>
                  <ul class="submenu-list">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          aria-current={isActive(child.href) ? 'page' : undefined}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      class="burger"
      id="burger"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Menu mobile (overlay) -->
  <div class="mobile-menu" id="mobile-menu" hidden>
    <ul>
      {
        NAV.map((item) => (
          <li>
            <a href={item.href} class={item.cta ? 'm-cta' : ''}>
              {item.label}
            </a>
            {item.children && (
              <ul class="m-sub">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href}>{child.label}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const burger = document.getElementById('burger');
  const panel = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    burger.setAttribute('aria-label', open ? 'Ouvrir le menu' : 'Fermer le menu');
    burger.classList.toggle('is-open', !open);
    if (panel) panel.hidden = open;
    document.body.style.overflow = open ? '' : 'hidden';
  });

  // Sous-menus desktop : ouverture au survol et au clavier (classe .open).
  document.querySelectorAll('.has-sub').forEach((li) => {
    li.addEventListener('mouseenter', () => li.classList.add('open'));
    li.addEventListener('mouseleave', () => li.classList.remove('open'));
    li.addEventListener('focusin', () => li.classList.add('open'));
    li.addEventListener('focusout', (e) => {
      if (!li.contains(e.relatedTarget)) li.classList.remove('open');
    });
  });
</script>

<style>
  header {
    position: fixed;
    top: 42px;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 14px 0;
    transition: all 0.4s ease;
    background: transparent;
  }
  header.scrolled {
    top: 0;
    padding: 13px 0;
  }
  /* Fond clair : au scroll (toutes pages) OU d'emblée sur page à bandeau clair. */
  header.scrolled,
  header.solid {
    background: rgba(250, 246, 240, 0.94);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 var(--line);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: var(--serif);
    font-size: 1.5rem;
    letter-spacing: 0.02em;
    color: var(--white);
    transition: color 0.4s;
    z-index: 2;
  }
  .logo .mark {
    font-style: italic;
    color: var(--gold);
  }
  header.scrolled .logo,
  header.solid .logo {
    color: var(--ink);
  }

  /* ===== MENU DESKTOP ===== */
  .menu {
    display: flex;
    gap: 30px;
    list-style: none;
    align-items: center;
  }
  .menu > li {
    position: relative;
  }
  .menu a {
    font-size: 0.8rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--white);
    font-weight: 500;
    transition: color 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  header.scrolled .menu a,
  header.solid .menu a {
    color: var(--ink-soft);
  }
  .menu a:hover,
  .menu a.active {
    color: var(--gold);
  }
  .caret {
    font-size: 0.7em;
    opacity: 0.8;
  }
  .nav-cta {
    border: 1px solid rgba(255, 255, 255, 0.5);
    padding: 9px 18px;
    border-radius: 30px;
    transition: all 0.3s;
  }
  header.scrolled .nav-cta,
  header.solid .nav-cta {
    border-color: var(--terra);
    color: var(--terra) !important;
  }
  .nav-cta:hover {
    background: var(--terra);
    border-color: var(--terra);
    color: var(--white) !important;
  }

  /* sous-menu — panneau « verre fumé » large, version poussée.
     Brief client : « transparence globale, quelque chose de plus large ».
     Parti pris tenu : verre FUMÉ SOMBRE (texte clair), pas verre clair.
     C'est le seul fond qui reste lisible sur les DEUX contextes réels
     observés à l'écran — le hero est lumineux (ciel pâle), un verre clair
     y noierait un texte sombre, et le crème scrollé est clair lui aussi.
     Un voile sombre translucide assombrit les deux fonds de façon homogène.

     Transparence poussée : l'opacité du fond passe de ~0.92 à ~0.60/0.70,
     on devine franchement le hero/contenu derrière. La lisibilité est
     sécurisée par TROIS leviers cumulés et non par l'opacité :
       1. backdrop-blur fort (22px) + saturation → le fond derrière fond
          en aplat coloré flou, aucun détail ne traverse le texte ;
       2. un dégradé sombre translucide qui garde le contraste minimal ;
       3. un léger text-shadow sur les items.
     Largeur : panneau ample multi-colonnes (en-tête de rubrique + grille
     d'items sur 2 colonnes dès 3 enfants), padding généreux. La largeur
     est justifiée par la mise en page, pas par du vide. */
  .submenu {
    position: absolute;
    top: 100%;
    left: -16px; /* aligne optiquement le bloc sur le label parent */
    margin-top: 14px;
    padding: 18px;
    width: 520px;
    max-width: min(520px, calc(100vw - 48px));
    background: linear-gradient(
      180deg,
      rgba(40, 33, 27, 0.62),
      rgba(30, 24, 19, 0.7)
    );
    -webkit-backdrop-filter: blur(22px) saturate(135%);
    backdrop-filter: blur(22px) saturate(135%);
    border: 1px solid rgba(199, 154, 78, 0.26);
    border-radius: 16px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.07) inset,
      0 26px 60px -14px rgba(20, 15, 10, 0.55);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition:
      opacity 0.26s ease,
      transform 0.26s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  /* Cas court (1 colonne, ≤2 items). Même famille visuelle que le panneau
     large, mais resserré : largeur plus étroite, padding réduit, en-tête
     empilé (titre puis « Tout voir » dessous → plus d'alignement bancal),
     items compacts. Le panneau ne doit plus paraître étiré ni vide. */
  .submenu[data-count='2'],
  .submenu[data-count='1'] {
    width: 268px;
    padding: 16px 14px 14px;
  }
  /* halo gold discret — signature reprise de Values / CtaBanner */
  .submenu::after {
    content: '';
    position: absolute;
    top: -36px;
    right: -24px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(199, 154, 78, 0.18),
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }
  .submenu::before {
    /* zone tampon pour ne pas perdre le survol entre label et panneau */
    content: '';
    position: absolute;
    top: -16px;
    left: 0;
    right: 0;
    height: 16px;
  }
  .has-sub.open > .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* en-tête de rubrique — donne du sens à la largeur et un point d'entrée
     direct vers la page mère. */
  .submenu-head {
    padding: 4px 12px 14px;
    margin-bottom: 8px;
    border-bottom: 1px solid rgba(199, 154, 78, 0.18);
  }
  .submenu-kicker {
    display: block;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 4px;
  }
  .submenu .submenu-title {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    font-family: var(--serif);
    font-size: 1.2rem;
    letter-spacing: 0.01em;
    text-transform: none;
    color: #fff !important;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
  }
  .submenu-all {
    font-family: var(--sans, inherit);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    color: rgba(250, 246, 240, 0.7);
    white-space: nowrap;
    transition: color 0.22s ease;
  }
  .submenu .submenu-title:hover {
    color: var(--gold) !important;
  }
  .submenu .submenu-title:hover .submenu-all {
    color: var(--gold);
  }

  /* En-tête — cas court : titre garanti sur une ligne (un peu plus petit),
     « Tout voir » empilé sous le titre et aligné à gauche. Fini le
     space-between qui collait le lien en haut à droite d'un titre sur 2 lignes. */
  .submenu[data-count='2'] .submenu-head,
  .submenu[data-count='1'] .submenu-head {
    padding: 2px 8px 10px;
    margin-bottom: 2px;
  }
  .submenu[data-count='2'] .submenu-title,
  .submenu[data-count='1'] .submenu-title {
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
    font-size: 1.08rem;
    white-space: nowrap;
  }
  .submenu[data-count='2'] .submenu-all,
  .submenu[data-count='1'] .submenu-all {
    font-size: 0.62rem;
  }

  /* grille d'items — 2 colonnes par défaut (panneau large),
     1 colonne pour les rubriques courtes. */
  .submenu-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px 10px;
    list-style: none;
  }
  .submenu[data-count='2'] .submenu-list,
  .submenu[data-count='1'] .submenu-list {
    grid-template-columns: 1fr;
    gap: 2px;
  }
  /* items compacts en cas court : moins de hauteur, indentation de puce
     resserrée pour combler le vide à gauche. */
  .submenu[data-count='2'] .submenu-list a,
  .submenu[data-count='1'] .submenu-list a {
    padding: 9px 14px 9px 26px;
  }
  .submenu[data-count='2'] .submenu-list a::before,
  .submenu[data-count='1'] .submenu-list a::before {
    left: 12px;
  }
  .submenu-list li {
    position: relative;
  }
  .submenu-list a {
    position: relative;
    display: block;
    padding: 11px 14px 11px 30px;
    border-radius: 10px;
    color: rgba(250, 246, 240, 0.9) !important;
    text-transform: none;
    letter-spacing: 0.01em;
    font-size: 0.94rem;
    font-weight: 400;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
    transition:
      color 0.22s ease,
      background 0.22s ease;
  }
  /* puce d'accent (terra au survol, gold sur l'actif), alignée optiquement */
  .submenu-list a::before {
    content: '';
    position: absolute;
    left: 14px;
    top: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--terra);
    transform: translateY(-50%) scale(0.5);
    opacity: 0;
    transition:
      opacity 0.22s ease,
      transform 0.22s ease;
  }
  .submenu-list a:hover {
    background: rgba(250, 246, 240, 0.1);
    color: #fff !important;
  }
  .submenu-list a:hover::before {
    opacity: 1;
    transform: translateY(-50%) scale(1);
  }
  .submenu-list a[aria-current='page'] {
    color: var(--gold) !important;
    background: rgba(199, 154, 78, 0.14);
  }
  .submenu-list a[aria-current='page']::before {
    opacity: 1;
    transform: translateY(-50%) scale(1);
    background: var(--gold);
  }
  @media (prefers-reduced-motion: reduce) {
    .submenu {
      transition: opacity 0.26s ease;
      transform: none;
    }
    .submenu-list a,
    .submenu-list a::before {
      transition: none;
    }
  }

  /* ===== BURGER ===== */
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 6px;
    z-index: 2;
  }
  .burger span {
    width: 26px;
    height: 2px;
    background: var(--white);
    transition: all 0.3s;
  }
  header.scrolled .burger span,
  header.solid .burger span {
    background: var(--ink);
  }
  .burger.is-open span {
    background: var(--ink);
  }
  .burger.is-open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger.is-open span:nth-child(2) {
    opacity: 0;
  }
  .burger.is-open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ===== MENU MOBILE ===== */
  .mobile-menu {
    position: fixed;
    inset: 0;
    top: 0;
    background: var(--bg);
    padding: 110px 32px 40px;
    overflow-y: auto;
    z-index: 1;
  }
  .mobile-menu ul {
    list-style: none;
  }
  .mobile-menu > ul > li {
    border-bottom: 1px solid var(--line);
  }
  .mobile-menu > ul > li > a {
    display: block;
    padding: 18px 0;
    font-family: var(--serif);
    font-size: 1.5rem;
    color: var(--ink);
  }
  .mobile-menu .m-cta {
    color: var(--terra);
  }
  .m-sub {
    padding: 0 0 16px 14px;
  }
  .m-sub a {
    display: block;
    padding: 7px 0;
    color: var(--ink-soft);
    font-size: 1rem;
  }

  @media (max-width: 980px) {
    nav {
      display: none;
    }
    .burger {
      display: flex;
    }
  }
  @media (min-width: 981px) {
    .mobile-menu {
      display: none;
    }
  }
</style>
