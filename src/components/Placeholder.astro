---
/**
 * Marqueur visuel « section en cours de rédaction ».
 * Sert pendant la phase contenu : chaque page du squelette en porte un,
 * qu'on remplace par le vrai contenu au fur et à mesure.
 */
interface Props {
  note?: string;
}
const { note } = Astro.props;
---

<section class="ph">
  <div class="container">
    <div class="ph-card">
      <span class="ph-tag">À rédiger</span>
      <p>{note ?? 'Contenu détaillé de cette page à venir (design + texte).'}</p>
      <slot />
    </div>
  </div>
</section>

<style>
  .ph-card {
    border: 1px dashed var(--line);
    border-radius: 8px;
    padding: 40px;
    text-align: center;
    color: var(--ink-soft);
    background: var(--white);
  }
  .ph-tag {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 600;
    border: 1px solid var(--terra);
    border-radius: 20px;
    padding: 4px 12px;
    margin-bottom: 14px;
  }
</style>
