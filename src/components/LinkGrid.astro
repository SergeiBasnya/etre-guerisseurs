---
/** Grille de cartes-liens, utilisée par les pages hub vers leurs enfants. */
export interface LinkCard {
  label: string;
  href: string;
  text?: string;
}
interface Props {
  cards: LinkCard[];
}
const { cards } = Astro.props;
---

<section class="lg">
  <div class="container">
    <div class="lg-grid">
      {
        cards.map((c) => (
          <a class="lg-card" href={c.href}>
            <h3>{c.label}</h3>
            {c.text && <p>{c.text}</p>}
            <span class="lg-link">Découvrir →</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .lg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 28px;
  }
  .lg-card {
    display: block;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 32px 30px;
    transition: all 0.35s ease;
  }
  .lg-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(46, 38, 32, 0.12);
    border-color: transparent;
  }
  .lg-card h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.4rem;
    margin-bottom: 12px;
  }
  .lg-card p {
    color: var(--ink-soft);
    font-size: 0.96rem;
    margin-bottom: 18px;
  }
  .lg-link {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 600;
  }
</style>
