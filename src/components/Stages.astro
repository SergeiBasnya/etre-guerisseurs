---
import { STAGES } from '../data/stages';
---

<section id="stages">
  <div class="container">
    <p class="eyebrow reveal">À ne pas manquer</p>
    <h2 class="section-title reveal">Nos prochains <span class="em">rendez-vous</span></h2>
    <p class="lede reveal">
      Des stages et retraites pensés comme des espaces de transformation, au
      contact des quatre éléments et au rythme des saisons.
    </p>
    <div class="cards">
      {
        STAGES.map((stage) => (
          <article class="card reveal">
            <div class="card-img">
              <span class="card-tag">{stage.tag}</span>
              <img src={stage.image} alt={stage.imageAlt} loading="lazy" />
            </div>
            <div class="card-body">
              <p class="card-meta">{stage.meta}</p>
              <h3>{stage.title}</h3>
              <p class="card-price">{stage.price}</p>
              <a class="card-link" href={stage.href}>
                Découvrir →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 54px;
  }
  .card {
    background: var(--white);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(46, 38, 32, 0.06);
    transition: all 0.4s ease;
    cursor: pointer;
  }
  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 40px rgba(46, 38, 32, 0.13);
  }
  .card-img {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    position: relative;
  }
  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s ease;
  }
  .card:hover .card-img img {
    transform: scale(1.06);
  }
  .card-tag {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(250, 246, 240, 0.92);
    color: var(--terra-deep);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 13px;
    border-radius: 20px;
    font-weight: 600;
  }
  .card-body {
    padding: 24px 26px 30px;
  }
  .card-meta {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .card-body h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.32rem;
    line-height: 1.25;
    margin-bottom: 14px;
  }
  .card-price {
    font-size: 0.95rem;
    color: var(--ink-soft);
    font-weight: 500;
  }
  .card-body .card-link {
    margin-top: 16px;
  }
  @media (max-width: 900px) {
    .cards {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
