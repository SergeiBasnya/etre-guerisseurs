---
import InnerPage from '../../layouts/InnerPage.astro';
import SplitFeature from '../../components/sections/SplitFeature.astro';
import InfoBox from '../../components/sections/InfoBox.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { ROUTES } from '../../consts';

// Géographie de la pratique depuis 2014 (signal d'autorité / E-E-A-T).
const references = [
  { region: 'Vaucluse (84)', lieux: 'Vedène, Cavaillon, Le Pontet, Avignon, Montfavet, Carpentras, Malaucène, Châteauneuf-de-Gadagne, L’Isle-sur-Sorgue' },
  { region: 'Gard (30)', lieux: 'Pujaut, Saze, Les Angles, Saint-Julien-la-Nef, Quissac, Salinelles' },
  { region: 'Bouches-du-Rhône (13)', lieux: 'Cabriès, Châteaurenard, Saint-Rémy-de-Provence' },
  { region: 'Drôme (26)', lieux: 'Ferrassières, Les Pilles' },
  { region: 'Isère (38)', lieux: 'Romagnieu, Faverges-de-la-Tour, Saint-Étienne-de-Crossey, Coublevie' },
  { region: 'Alpes-Maritimes (06)', lieux: 'Nice, Saint-Auban, Mougins' },
  { region: 'Autres régions', lieux: 'Paris (75), Annecy (74), Briançon (05), Brissac (34), Sougraignes (11), Saint-Pierre-de-Rivières (09), Saint-Laurent-de-Gosse (40)' },
  { region: 'International', lieux: 'Essaouira (Maroc) · Genthod & La Forclaz (Suisse)' },
];

const materiel = [
  'Vêtements adaptés aux soirées de saison',
  'Tapis de sol, petit coussin et couverture légère',
  'De quoi noter, éventuellement',
];
---

<InnerPage
  eyebrow="Accompagnement · Pardon"
  h1="Guérir le cœur par les Cercles de Pardon"
  lede="Rituel toltèque transpersonnel de guérison du cœur, dans la lignée de Don Miguel Ruiz et d’Olivier Clerc — doux et puissant à la fois."
  description="Cercles et stages de Pardon toltèque animés par Pierre-Alexandre Morales depuis 2014 : un rituel de guérison du cœur, accessible à tous, en Provence et au-delà."
  crumbs={[
    { label: 'Accompagnement', href: ROUTES.accompagnement },
    { label: 'Cercle de Pardon', href: ROUTES.cerclePardon },
  ]}
  bandImage="https://images.unsplash.com/photo-1602192509154-0b900ee1f851?q=80&w=2000&auto=format&fit=crop"
>
  <SplitFeature
    eyebrow="La Médecine toltèque du Pardon"
    title="Une <span class='em'>Médecine</span> pour les cœurs blessés"
    paragraphs={[
      "Les rituels de Pardon font partie intégrante de la transmission de Don Miguel Ruiz. En cercle ou en file, statiques ou en mouvement, individuels ou collectifs, ils opèrent comme une véritable Médecine — au sens où l’emploient les Amérindiens — capable de guérir les cœurs blessés. Nous avons tous nos propres blessures…",
      "Entreprendre de les guérir demande courage et force, détermination et engagement, vulnérabilité et douceur. Le chemin du pardon emprunté par Don Miguel nous accompagne vers le pardon de notre âme : acte suprême pour se libérer de la prison du poison émotionnel qui empêche de vivre le cœur en paix.",
      "Une fois ce pardon accompli, chacun peut franchir une nouvelle porte vers plus de liberté, de simplicité, de fluidité — et acquiert un nouveau pouvoir personnel. La Médecine Toltèque du Pardon est une voie royale pour guérir son cœur.",
    ]}
    image="https://images.unsplash.com/photo-1518002171953-a080ee817e1f?q=80&w=1400&auto=format&fit=crop"
    imageAlt="Cercle de parole et de pardon"
    bg="cream"
  />

  <section class="band bg-warm">
    <div class="container">
      <blockquote class="pardon-quote">
        <p>
          « L’acte de pardon suprême, c’est de pouvoir vous pardonner à
          vous-même pour toutes les blessures que vous avez provoquées dans
          votre vie. Le pardon est un acte d’amour envers soi-même. Quand vous
          vous pardonnez, vous commencez à vous accepter et à vous aimer
          davantage. »
        </p>
        <cite>Don Miguel Ruiz</cite>
      </blockquote>
    </div>
  </section>

  <SplitFeature
    eyebrow="Le Cercle de Pardon®"
    title="Un rituel <span class='em'>transpersonnel</span>, accessible à tous"
    paragraphs={[
      "Le Cercle de Pardon® a été initié en 2012 par Olivier Clerc — alors traducteur de Don Miguel Ruiz — et s’inspire directement du rituel vécu au Mexique, à Teotihuacan, avec Don Miguel Ruiz. Ce sont des rituels de deux à trois heures pour vivre le Pardon avec soi et avec les autres, dans l’énergie collective d’un groupe qui fait office d’humanité le temps du rituel.",
      "Olivier Clerc a élaboré ce rituel sur la base de sa propre expérience auprès de Don Miguel Ruiz, puis en a tiré un livre, <em>Le Don du Pardon — un cadeau toltèque de Don Miguel Ruiz</em>.",
      "L’énergie y est douce et puissante à la fois, la démarche respectueuse de chacun là où il en est, et de toute confession : l’approche est universelle et transpersonnelle. Des temps de parole et d’échange alternent avec des exercices thérapeutiques et des rituels.",
      "Il est accessible à toute personne prête au pardon, désireuse de pardonner et de se mettre en quête de guérison. <em>Ne me croyez pas, mais venez le vérifier — bienvenue !</em>",
    ]}
    image="https://images.unsplash.com/photo-1529333166437-7750a6dd5a70?q=80&w=1400&auto=format&fit=crop"
    imageAlt="Groupe en cercle, énergie collective"
    reverse
    bg="cream"
  />

  <section class="band bg-warm">
    <div class="container">
      <div class="exp">
        <p class="exp-eyebrow">Une pratique éprouvée</p>
        <p class="exp-lede">
          Animateur de Cercle de Pardon depuis avril 2014 — principalement en
          Provence et dans le Languedoc, mais aussi ailleurs en France et à
          l’étranger, pour des groupes d’hommes, de femmes, des festivals et des
          rencontres. Plus de douze ans d’animation : grâce aux nombreux
          animateurs formés dans le monde francophone, ce rituel a déjà aidé des
          centaines de personnes — en France, en Europe, aux Antilles, en
          Guyane — à guérir leur cœur.
        </p>
        <div class="refs-grid">
          {references.map((r) => (
            <div class="ref">
              <h3>{r.region}</h3>
              <p>{r.lieux}</p>
            </div>
          ))}
        </div>
        <p class="refs-note">
          Également en festivals et lieux partenaires : Semaine mondiale de la
          Gentillesse (Avignon), Les Chemins de l’Éveil en Provence
          (Châteaurenard), Rencontres du Masculin & du Féminin Sacré, Carrefours
          de Vie (Annecy), Harmonie & Conscience (Paris), Péniche Althéa
          (Avignon), Centre de soins Champlain (Orange)…
        </p>
      </div>
    </div>
  </section>

  <section class="band bg-cream">
    <div class="container">
      <div class="modal-head">
        <p class="eyebrow">Modalités pratiques</p>
        <h2 class="section-title">
          Vivre un <span class="em">Cercle de Pardon</span>
        </h2>
        <p class="lede">
          Rituel toltèque thérapeutique pour guérir les blessures du cœur et
          vivre des relations renouvelées et apaisées. À vivre pour pardonner,
          se pardonner et libérer son cœur.
        </p>
      </div>
      <InfoBox
        rows={[
          { label: 'Format', value: 'Rituel collectif · 2h à 3h' },
          { label: 'Public', value: 'Toute personne prête au pardon · toute confession' },
          { label: 'Participation', value: '20 à 30 €' },
        ]}
        ctaLabel="Nous contacter"
        ctaHref={ROUTES.contact}
      />
      <p class="modal-note">
        Frais de communication, de diffusion, de location et collation
        d’accueil inclus. Nous consulter si besoin.
      </p>
      <div class="materiel">
        <p class="materiel-label">Matériel à apporter</p>
        <ul>
          {materiel.map((m) => <li>{m}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <CtaBanner
    eyebrow="Médecine du Pardon"
    title="Cela vous <span class='em'>inspire</span> ?"
    text="Mon intention est de porter partout cette Médecine du Pardon et d’en être le serviteur. Apprendre à s’accepter facilite grandement la vie. Échangeons pour trouver le bon moment."
    ctaLabel="Nous contacter"
    ctaHref={ROUTES.contact}
    altLabel="Voir l’agenda"
    altHref={ROUTES.agenda}
    variant="ink"
  />
</InnerPage>

<style>
  .band {
    padding: 90px 0;
  }
  .band.bg-cream {
    background: var(--bg);
  }
  .band.bg-warm {
    background: var(--bg-warm);
  }

  /* Citation Don Miguel */
  .pardon-quote {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }
  .pardon-quote p {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.3rem, 2.6vw, 1.8rem);
    line-height: 1.45;
    color: var(--ink);
  }
  .pardon-quote cite {
    display: block;
    margin-top: 22px;
    font-style: normal;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 600;
  }

  /* Pratique éprouvée + références */
  .exp-eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .exp-lede {
    max-width: 760px;
    color: var(--ink-soft);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 40px;
  }
  .refs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 26px 36px;
  }
  .ref h3 {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 600;
    margin-bottom: 6px;
  }
  .ref p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .refs-note {
    margin-top: 34px;
    max-width: 820px;
    color: var(--ink-soft);
    font-size: 0.92rem;
    font-style: italic;
    line-height: 1.6;
  }

  /* Modalités */
  .modal-head {
    max-width: 720px;
    margin-bottom: 8px;
  }
  .modal-note {
    margin-top: 16px;
    color: var(--ink-soft);
    font-size: 0.9rem;
    font-style: italic;
  }
  .materiel {
    margin-top: 34px;
    padding: 24px 28px;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 8px;
    max-width: 560px;
  }
  .materiel-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .materiel ul {
    list-style: none;
    display: grid;
    gap: 9px;
  }
  .materiel li {
    position: relative;
    padding-left: 20px;
    color: var(--ink-soft);
    font-size: 0.96rem;
  }
  .materiel li::before {
    content: '◈';
    position: absolute;
    left: 0;
    top: 1px;
    color: var(--gold);
    font-size: 0.7rem;
  }

  @media (max-width: 900px) {
    .band {
      padding: 64px 0;
    }
  }
</style>
