---
import InnerPage from '../../layouts/InnerPage.astro';
import eventsData from '../../data/events.json';
import { ROUTES } from '../../consts';

interface AgendaEvent {
  id: string;
  slug?: string;
  day: string;
  month: string;
  year?: string;
  title: string;
  description?: string;
  paragraphs?: string[];
  programme?: string[];
  image?: string;
  imageAlt?: string;
  location?: string;
  address?: string;
  dateRange?: string;
  price: string;
  free: boolean;
  url: string;
  fbUrl?: string;
}

export function getStaticPaths() {
  const events = (eventsData.events as AgendaEvent[]) ?? [];
  return events.map((ev) => ({
    params: { slug: ev.slug ?? ev.id },
    props: { ev },
  }));
}

const { ev } = Astro.props as { ev: AgendaEvent };

const slug = ev.slug ?? ev.id;
const dateRange = ev.dateRange ?? [ev.day, ev.month, ev.year].filter(Boolean).join(' ');
const place = (ev.address ?? ev.location ?? '').split('·')[0].trim();
const maps = place
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(place)}`
  : null;
const paragraphs = ev.paragraphs ?? (ev.description ? [ev.description] : []);

const isFb = Boolean(ev.fbUrl) || (ev.url ?? '').includes('facebook');
const ctaHref = ev.fbUrl ?? (ev.url && ev.url !== '#contact' ? ev.url : ROUTES.contact);
const ctaLabel = isFb ? "S'inscrire sur Facebook" : 'Nous contacter';
---

<InnerPage
  eyebrow={`Agenda · ${dateRange}`}
  h1={ev.title}
  lede={ev.location}
  description={ev.description}
  crumbs={[
    { label: 'Agenda', href: ROUTES.agenda },
    { label: ev.title, href: `${ROUTES.agenda}${slug}/` },
  ]}
>
  <section class="ev-detail">
    <div class="container ev-grid">
      {
        ev.image && (
          <div class="ev-poster">
            <img src={ev.image} alt={ev.imageAlt ?? ev.title} />
          </div>
        )
      }

      <div class={ev.image ? 'ev-info' : 'ev-info is-wide'}>
        <dl class="ev-facts">
          <div>
            <dt>Dates</dt>
            <dd>{dateRange}</dd>
          </div>
          {
            ev.location && (
              <div>
                <dt>Lieu</dt>
                <dd>
                  {ev.location}
                  {maps && (
                    <a class="ev-map" href={maps} target="_blank" rel="noopener">
                      + Google Maps
                    </a>
                  )}
                </dd>
              </div>
            )
          }
          <div>
            <dt>Tarif</dt>
            <dd>{ev.price}</dd>
          </div>
        </dl>

        {paragraphs.map((p) => <p class="ev-para" set:html={p} />)}

        {
          ev.programme && (
            <div class="ev-prog">
              <p class="prog-label">Au programme</p>
              <ul>
                {ev.programme.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          )
        }

        <div class="ev-cta">
          <a
            class="btn"
            href={ctaHref}
            {...(isFb ? { target: '_blank', rel: 'noopener' } : {})}
          >
            {ctaLabel}
          </a>
          <a class="card-link" href={ROUTES.agenda}>← Retour à l'agenda</a>
        </div>
      </div>
    </div>
  </section>
</InnerPage>

<style>
  .ev-detail {
    padding: 80px 0;
  }
  .ev-grid {
    display: grid;
    grid-template-columns: minmax(280px, 420px) 1fr;
    gap: 56px;
    align-items: start;
  }
  .ev-poster {
    position: sticky;
    top: 120px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: 0 14px 36px rgba(46, 38, 32, 0.12);
  }
  .ev-poster img {
    width: 100%;
    height: auto;
    display: block;
  }
  .ev-info.is-wide {
    grid-column: 1 / -1;
    max-width: 760px;
  }

  .ev-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 18px 44px;
    padding: 22px 26px;
    margin-bottom: 32px;
    background: var(--bg-warm);
    border-radius: 8px;
  }
  .ev-facts dt {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 3px;
  }
  .ev-facts dd {
    font-family: var(--serif);
    font-size: 1.08rem;
    color: var(--ink);
  }
  .ev-map {
    display: inline-block;
    margin-left: 10px;
    font-family: var(--sans, inherit);
    font-size: 0.85rem;
    color: var(--terra);
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s ease;
  }
  .ev-map:hover {
    border-bottom-color: var(--terra);
  }

  .ev-para {
    color: var(--ink-soft);
    margin-bottom: 16px;
    line-height: 1.65;
  }

  .ev-prog {
    margin: 30px 0 8px;
  }
  .prog-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .ev-prog ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 9px 28px;
  }
  .ev-prog li {
    position: relative;
    padding-left: 20px;
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.45;
  }
  .ev-prog li::before {
    content: '◈';
    position: absolute;
    left: 0;
    top: 1px;
    color: var(--gold);
    font-size: 0.7rem;
  }

  .ev-cta {
    margin-top: 38px;
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  @media (max-width: 820px) {
    .ev-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .ev-poster {
      position: static;
      max-width: 360px;
    }
    .ev-prog ul {
      grid-template-columns: 1fr;
    }
  }
</style>
