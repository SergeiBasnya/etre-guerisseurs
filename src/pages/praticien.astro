---
import InnerPage from '../layouts/InnerPage.astro';
import SplitFeature from '../components/sections/SplitFeature.astro';
import Prose from '../components/sections/Prose.astro';
import Timeline from '../components/sections/Timeline.astro';
import IconList from '../components/sections/IconList.astro';
import VideoEmbed from '../components/sections/VideoEmbed.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { ROUTES, SITE, SOCIALS, asset } from '../consts';

// Interview média « Plan Zen » — signal d'autorité / preuve de presse (E-E-A-T).
const VIDEO = {
  id: 'l-v0UI-3h5c',
  title: 'Plan Zen avec Pierre-Alexandre Morales — Guérir par les enseignements toltèques',
};
const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: VIDEO.title,
  description:
    'Interview de Pierre-Alexandre Morales dans l’émission « Plan Zen » : guérir et s’accomplir par la voie et les enseignements toltèques.',
  thumbnailUrl: new URL(asset('video-plan-zen.webp'), SITE.url).href,
  embedUrl: `https://www.youtube-nocookie.com/embed/${VIDEO.id}`,
  contentUrl: `https://www.youtube.com/watch?v=${VIDEO.id}`,
  publisher: { '@id': `${SITE.url}/#business` },
};

const parcours = [
  {
    date: 'Formation initiale',
    title: 'Lettres & pédagogie',
    text: "Maîtrise de Lettres Modernes (mention, Université d'Avignon) et D.U. de Formateur-Animateur.",
  },
  {
    date: 'Depuis 2011',
    title: 'Coaching & PNL',
    text: "Certification au métier de coach et à l'accompagnement professionnel, Praticien PNL (Formation Évolution & Synergie, avec Gilles Roy). Création du Coaching d'Être.",
  },
  {
    date: '2012 – 2015',
    title: 'CAFE-CO, Avignon',
    text: "Fondateur et animateur d'un Café-Coaching réunissant quinze coaches et praticiens, touchant plusieurs centaines de personnes.",
  },
  {
    date: 'La rencontre',
    title: 'Don Miguel & Don José Ruiz',
    text: "Initié à la voie toltèque par Don Miguel Ruiz : « Tu es la vérité. La vérité te rend libre. » Invitation à poursuivre la transmission, avec la validation de Don José Ruiz, co-auteur du Cinquième Accord.",
    highlight: true,
  },
  {
    date: 'Cercles & jeu',
    title: 'Formé par Olivier Clerc',
    text: 'Animateur du Jeu des Accords Toltèques et des Cercles de Pardon, formé auprès d’Olivier Clerc.',
  },
  {
    date: 'Magnétisme',
    title: 'École des Guérisseurs',
    text: 'Formé au magnétisme par Jean-Marie Bataille, puis par George Bergoz, fondateur de l’École des Guérisseurs.',
  },
  {
    date: 'Depuis 2017',
    title: 'Transmettre, partout et pour tous',
    text: 'Stages dans la voie toltèque en France, au Maroc, en Suisse ; ateliers pour expliquer les Accords Toltèques aux enfants en écoles maternelles.',
  },
];

const formations = [
  { icon: 'spark', title: 'Coach certifié', text: 'Métier de coach & accompagnement professionnel.' },
  { icon: 'circle', title: 'Praticien PNL', text: 'Formation Évolution & Synergie (Gilles Roy).' },
  { icon: 'leaf', title: 'Formateur-Animateur', text: "Diplôme universitaire (D.U.)." },
  { icon: 'heart', title: 'Voie toltèque', text: 'Initié par Don Miguel & Don José Ruiz.' },
  { icon: 'hand', title: 'Magnétisme', text: 'École des Guérisseurs (George Bergoz).' },
  { icon: 'moon', title: 'Cercles de Pardon', text: 'Formé par Olivier Clerc.' },
];

// Schema.org Person — ancre l'autorité du praticien (E-E-A-T, Knowledge Graph).
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE.url}/praticien/#person`,
  name: SITE.intervenant,
  jobTitle: 'Enseignant toltèque, accompagnant et magnétiseur',
  description:
    'Enseignant, coach et magnétiseur, formé à la voie toltèque par Don Miguel et Don José Ruiz.',
  url: new URL(ROUTES.praticien, SITE.url).href,
  image: new URL(asset('pierre-alexandre.webp'), SITE.url).href,
  worksFor: { '@id': `${SITE.url}/#business` },
  knowsAbout: [
    'Voie toltèque',
    'Accords toltèques',
    'Magnétisme',
    'Soins énergétiques',
    'Coaching',
    'Cercles de Pardon',
    'PNL',
  ],
  hasCredential: [
    'Coach certifié — métier de coach & accompagnement professionnel',
    'Praticien PNL (Formation Évolution & Synergie)',
    'Magnétisme — École des Guérisseurs (George Bergoz)',
  ].map((name) => ({ '@type': 'EducationalOccupationalCredential', name })),
  sameAs: Object.values(SOCIALS).filter((u) => u !== '#'),
};
---

<InnerPage
  eyebrow="Le praticien"
  h1="Pierre-Alexandre Morales"
  lede="Enseignant et formateur, éclaireur dans la voie toltèque. La transmission est mon cœur de métier."
  description="Pierre-Alexandre Morales : enseignant, coach et magnétiseur, formé à la voie toltèque par Don Miguel et Don José Ruiz. Parcours, formations et approche."
  crumbs={[{ label: 'Le praticien', href: ROUTES.praticien }]}
  hideClosing
  bandImage="https://images.unsplash.com/photo-1544027993-37dbfe43562a?q=80&w=2000&auto=format&fit=crop"
>
  <SplitFeature
    eyebrow="Mon approche"
    title="Transmettre par <span class='em'>l'exemple</span>"
    paragraphs={[
      "Je suis enseignant et formateur, c'est mon cœur de métier. Coach de vie en Coaching d'Être — une approche relationnelle dynamique que j'ai conçue avec les Accords Toltèques comme principal outil d'accompagnement au changement.",
      "Les Accords Toltèques, outil de connaissance de soi, de communication et d'exploration de la conscience, sont le support numéro un que j'utilise en coaching comme en formation : d'abord en autodidacte auprès du public durant cinq ans, puis formé par Olivier Clerc, Don Miguel et Don José Ruiz.",
      "Mon intention : aider chacun, au travers de ma démarche d'éclaireur dans la voie toltèque, à réaliser son rêve de liberté et de bonheur personnel — partout et pour tous.",
    ]}
    image={asset('pierre-alexandre.webp')}
    imageAlt="Pierre-Alexandre Morales, praticien"
    bg="cream"
  />

  <Prose
    bg="white"
    eyebrow="Le récit"
    title="Son <span class='em'>parcours</span>, en détail"
    toc={[
      { label: 'De l’accompagnement au soin', anchor: 'accompagnement' },
      { label: 'Le chemin spirituel', anchor: 'voie-tolteque' },
      { label: 'Approfondir la guérison', anchor: 'guerison' },
      { label: 'Transmettre, partout et pour tous', anchor: 'transmettre' },
      { label: 'Aujourd’hui : présence & distance', anchor: 'aujourdhui' },
    ]}
  >
    <p class="pz-standfirst">
      Découvrant dans son parcours de formateur une aptitude à écouter et à
      accompagner individuellement, Pierre-Alexandre Morales a peu à peu fait de
      la relation d'aide le cœur de sa vie.
    </p>

    <h2 id="accompagnement">De l'accompagnement au soin</h2>
    <p>
      Il se forme d'abord aux techniques d'accompagnement au changement en milieu
      professionnel — coaching et PNL — auprès de l'organisme Synergie &amp;
      Évolution, fondé par Gilles Roy, pionnier du métier de coach en France.
    </p>
    <p>
      Il se forme ensuite au magnétisme dans différentes écoles, dont notamment
      l'Institut Supérieur de Reboutement – École des Guérisseurs de George
      Bergoz. Il y découvre, dans le même temps, une aptitude à soigner et à
      soulager la douleur et la souffrance humaines, et intègre dès lors plus
      pleinement la relation d'aide à sa vie quotidienne.
    </p>

    <h2 id="voie-tolteque">Le chemin spirituel et la voie toltèque</h2>
    <p>
      Commencée à l'âge de vingt et un ans, sa formation spirituelle se poursuit
      par diverses initiations chamaniques durant une quinzaine d'années,
      principalement amérindiennes — dont la voie toltèque, dont l'intention est
      de devenir le créateur de sa vie et d'en faire une œuvre d'art.
    </p>
    <blockquote>
      Devenir le créateur de sa vie, et en faire une œuvre d'art.
    </blockquote>
    <p>
      Il n'a de cesse, depuis, de transmettre partout ces enseignements qui
      permettent de vivre en accord avec la nature et avec notre nature
      individuelle, sous forme de cours annuels sur table, d'ateliers et de
      stages de formation en immersion.
    </p>

    <h2 id="guerison">Approfondir la guérison</h2>
    <p>
      Dans les années 2020, il achève par ailleurs cette formation spirituelle à
      l'Institut Arc en Ciel, fondé par Florent Dechoz et George
      Marie-Magdelaine, par de nouveaux apprentissages de guérison personnelle et
      de techniques de soins énergétiques.
    </p>
    <p>
      Il y combine la Roue de Médecine amérindienne — marchée dans les deux sens,
      quatre années durant — et la caractérologie des blessures de Reich et
      Lowen, vulgarisée par le développement personnel à l'américaine sous la
      forme des cinq blessures, en lien avec chacune des directions de la Roue.
      Un programme riche et transformateur.
    </p>

    <h2 id="transmettre">Transmettre, partout et pour tous</h2>
    <p>
      Partout et pour tous, il a à cœur de transmettre le message toltèque de
      liberté, de maîtrise et d'amour. Il accompagne en coaching avec les outils
      de la voie toltèque et soigne en cabinet par le magnétisme et les soins
      énergétiques.
    </p>
    <p>
      Depuis près de douze ans, il est aussi animateur de Cercles de Pardon ®,
      rituel toltèque de guérison des blessures du cœur initié par Olivier Clerc,
      et anime des ateliers sur le Pardon pour apprendre à mieux accepter les
      faits et à s'accepter soi-même.
    </p>
    <p>
      Il anime également, par intermittence, des Tentes Blanches — cercles de
      parole pour hommes inspirés de la tradition amérindienne — et accompagne
      des groupes pour intégrer les enseignements toltèques par la marche dans la
      nature.
    </p>

    <h2 id="aujourdhui">Aujourd'hui : en présence et à distance</h2>
    <p>
      Son activité actuelle se concentre sur les cours, les formations et
      l'accompagnement personnalisé aux Accords Toltèques, en présence et à
      distance, pour particuliers, professionnels, familles et jeune public.
      S'y ajoutent des accompagnements aux accords par la marche dans la nature,
      ainsi que des co-créations mariant enseignement toltèque et autres
      approches — notamment la musique, le chant et la danse.
    </p>
    <img
      src="/pierre-alexandre-morales-enseignant-tolteque.webp"
      alt="Pierre-Alexandre Morales, enseignant toltèque, adossé à un mur de pierre face au paysage de la Drôme provençale"
      width="1400"
      height="933"
      loading="lazy"
    />
    <p>
      Considérant le temps présent, son enseignement se divise en une partie en
      présence et une autre à distance, afin de répondre à un public large et
      concerné.
    </p>
    <p>
      Ouvert aux rencontres, et curieux de ces rencontres, il participe
      régulièrement à des co-créations et des co-animations avec des partenaires
      qui aiment, comme lui, marier des approches opposées et complémentaires —
      la plus récente étant une conférence sur les mythes et légendes des Anciens
      Toltèques, illustrée musicalement par un artiste musicien.
    </p>
  </Prose>

  <Timeline
    eyebrow="Parcours & formations"
    title="Un chemin au service de <span class='em'>la transmission</span>"
    entries={parcours}
    bg="warm"
  />

  <IconList
    eyebrow="Formations & certifications"
    title="Des <span class='em'>repères</span> solides"
    items={formations}
    columns={3}
    bg="cream"
  />

  <section class="media bg-warm">
    <div class="container">
      <p class="eyebrow">Dans les médias</p>
      <h2 class="section-title">
        Pierre-Alexandre <span class="em">en vidéo</span>
      </h2>
      <p class="lede">
        La voie toltèque, le soin et l’accompagnement — en interview comme en
        conférence, expliqués simplement.
      </p>
      <div class="media-grid">
        <figure class="media-item">
          <div class="media-video">
            <VideoEmbed id={VIDEO.id} title={VIDEO.title} poster={asset('video-plan-zen.webp')} />
          </div>
          <figcaption>
            Émission « Plan Zen » — guérir par les enseignements toltèques.
          </figcaption>
        </figure>
        <figure class="media-item">
          <div class="vimeo-embed">
            <iframe
              src="https://player.vimeo.com/video/301655337?dnt=1&title=0&byline=0&portrait=0"
              title="Conférence de Pierre-Alexandre Morales sur la voie toltèque"
              loading="lazy"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              referrerpolicy="strict-origin-when-cross-origin"></iframe>
          </div>
          <figcaption>
            En conférence — la voie toltèque, « partout et pour tous ».
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <CtaBanner
    eyebrow="Faire connaissance"
    title="« C'est en vous aimant que vous changerez <span class='em'>le monde.</span> »"
    text="Don Miguel & Don José Ruiz — Échangeons sur votre chemin."
    ctaLabel="Prendre contact"
    ctaHref={ROUTES.contact}
    altLabel="Voir l'agenda"
    altHref={ROUTES.agenda}
    variant="warm"
  />

  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />
</InnerPage>

<style>
  .media {
    padding: 90px 0;
  }
  .media.bg-warm {
    background: var(--bg-warm);
  }
  .media-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 36px;
    align-items: start;
  }
  .media-item {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .media-item figcaption {
    font-size: 0.96rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .vimeo-embed {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    background: var(--ink);
    box-shadow: 0 14px 40px rgba(46, 38, 32, 0.16);
  }
  .vimeo-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .media .lede {
    max-width: 640px;
    margin-bottom: 36px;
  }
  .media-video {
    width: 100%;
  }
  @media (max-width: 760px) {
    .media-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 900px) {
    .media {
      padding: 64px 0;
    }
  }
</style>
