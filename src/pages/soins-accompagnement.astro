---
import InnerPage from '../layouts/InnerPage.astro';
import LinkGrid from '../components/LinkGrid.astro';
import { ROUTES } from '../consts';

const cards = [
  {
    label: 'Soins énergétiques',
    href: ROUTES.soinsEnergetiques,
    text: 'Magnétisme, mains lumière et soins à distance : recevoir, relâcher, retrouver son équilibre.',
  },
  {
    label: 'Accompagnement & coaching',
    href: ROUTES.coaching,
    text: 'Cheminer, dénouer ses blocages émotionnels et devenir le créateur de sa vie, séance après séance.',
  },
];
---

<InnerPage
  eyebrow="Soins & accompagnement"
  h1="Être soigné, être accompagné"
  lede="Que vous cherchiez à recevoir un soin ou à être accompagné dans un cheminement, deux voies complémentaires pour revenir à l'essentiel."
  crumbs={[{ label: 'Soins & accompagnement', href: ROUTES.soins }]}
>
  <LinkGrid cards={cards} />
</InnerPage>
