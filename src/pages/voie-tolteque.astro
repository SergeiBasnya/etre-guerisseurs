---
import InnerPage from '../layouts/InnerPage.astro';
import LinkGrid from '../components/LinkGrid.astro';
import Placeholder from '../components/Placeholder.astro';
import { ROUTES } from '../consts';

const cards = [
  {
    label: 'Les accords toltèques',
    href: ROUTES.accords,
    text: 'Quatre accords pour se libérer des croyances limitantes et retrouver sa liberté intérieure.',
  },
  {
    label: 'Les cercles de pardon',
    href: ROUTES.cercles,
    text: 'Un rituel de libération pour déposer le poids du passé et se réconcilier avec soi.',
  },
];
---

<InnerPage
  eyebrow="La voie toltèque"
  h1="La voie toltèque"
  lede="Une sagesse ancestrale, transmise par la lignée de Don Miguel Ruiz, pour devenir le créateur de sa vie et en faire une œuvre d'art."
  crumbs={[{ label: 'La voie toltèque', href: ROUTES.voie }]}
>
  <Placeholder note="Page pilier : qu'est-ce que la voie toltèque, son origine, ses principes. Carrefour SEO/IA qui pousse vers les soins, l'accompagnement et les stages." />
  <LinkGrid cards={cards} />
</InnerPage>
