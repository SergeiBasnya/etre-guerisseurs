---
import InnerPage from '../layouts/InnerPage.astro';
import { ROUTES, CONTACT } from '../consts';
---

<InnerPage
  eyebrow="Contact"
  h1="Prendre contact"
  lede="Une question, une envie d'accompagnement ou de stage ? Écrivez-moi ou appelez le cabinet."
  crumbs={[{ label: 'Contact', href: ROUTES.contact }]}
  hideClosing
>
  <section>
    <div class="container contact-grid">
      <div class="coords">
        <h2 class="section-title">Le cabinet</h2>
        <ul>
          <li>
            <strong>Adresse</strong>
            {CONTACT.address.street}<br />
            {CONTACT.address.zip} {CONTACT.address.city}
          </li>
          <li>
            <strong>Téléphone</strong>
            <a href={CONTACT.phoneHref}>{CONTACT.phone}</a>
          </li>
          <li>
            <strong>Email</strong>
            <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
          </li>
          <li>
            <strong>Consultations également à</strong>
            {CONTACT.areaServed.join(' · ')}
          </li>
          <li>
            <strong>À distance</strong>
            {CONTACT.remote}
          </li>
        </ul>
      </div>

      {/* Netlify Forms : la détection se fait sur le HTML statique généré au
          build (name + data-netlify + champ caché form-name + honeypot). Les
          messages arrivent dans Netlify → Forms, avec notification email. */}
      <form
        class="contact-form"
        name="contact"
        method="POST"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        action={`${ROUTES.contact}?envoye=1`}
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hp" hidden>
          <label>Ne pas remplir : <input name="bot-field" /></label>
        </p>
        <p class="form-ok" role="status" hidden>
          Merci, votre message a bien été envoyé. Je vous réponds au plus vite.
        </p>
        <label>Nom <input type="text" name="name" required /></label>
        <label>Email <input type="email" name="email" required /></label>
        <label>Téléphone <input type="tel" name="phone" /></label>
        <label>Message <textarea name="message" rows="5" required></textarea></label>
        <label class="consent">
          <input type="checkbox" name="consent" required />
          <span>
            J'accepte que mes informations soient utilisées pour répondre à ma
            demande, conformément à la <a href={ROUTES.confidentialite}>politique
            de confidentialité</a>.
          </span>
        </label>
        <button type="submit" class="btn">Envoyer</button>
      </form>
    </div>
  </section>
</InnerPage>

<script>
  // Netlify redirige vers ?envoye=1 après soumission réussie : on révèle la
  // confirmation et on nettoie l'URL.
  if (new URLSearchParams(location.search).has('envoye')) {
    document.querySelector('.form-ok')?.removeAttribute('hidden');
    history.replaceState(null, '', location.pathname);
  }
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 60px;
  }
  .coords ul {
    list-style: none;
    margin-top: 24px;
  }
  .coords li {
    margin-bottom: 22px;
    color: var(--ink-soft);
  }
  .coords strong {
    display: block;
    color: var(--ink);
    font-weight: 600;
    margin-bottom: 4px;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .coords a {
    color: var(--terra);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink);
  }
  .contact-form input,
  .contact-form textarea {
    font-family: inherit;
    font-size: 1rem;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--white);
    color: var(--ink);
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: 2px solid var(--terra);
    outline-offset: 1px;
  }
  .contact-form .btn {
    align-self: flex-start;
    border: 0;
    cursor: pointer;
    margin-top: 4px;
  }
  /* Champ anti-spam (honeypot) — masqué aux humains. */
  .hp {
    position: absolute;
    left: -9999px;
  }
  .consent {
    flex-direction: row;
    align-items: flex-start;
    gap: 10px;
    font-weight: 400;
    font-size: 0.82rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .consent input {
    margin-top: 3px;
    flex-shrink: 0;
  }
  .consent a {
    color: var(--terra);
  }
  .form-ok {
    background: var(--bg-warm);
    border: 1px solid var(--sage);
    border-radius: 6px;
    padding: 14px 16px;
    font-size: 0.92rem;
    color: var(--ink);
  }
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
